// The OpenArm v2.0 gripper: a revolute pinch gripper on a single DM4310 driven in
// POS_FORCE mode (position command with a speed and grip-force limit), reporting measured
// grip force on gripper_states. One instance per side, selected by `gripper_id`. Distinct
// node from openarm_gripper (v1.0 prismatic, MIT); a launcher deploys one or the other.
{
  peppy_schema: "node/v1",
  manifest: {
    name: "openarm_gripper_v2",
    tag: "v1",
    implements: [
      // Measured opening on the generic joint_states contract (positions[0]),
      // with the sensed grip force as effort[0], for any observer such as a
      // recorder. The backbone's control-loop state feed is the gripper_link
      // pairing, not this contract.
      { name: "joint_states", tag: "v1", link_id: "states" },
      // The opening setpoint commanded to this gripper on the generic
      // joint_commands contract, so a recorder captures the action aligned with
      // the measured opening above. Per-gripper here (the backbone that computes
      // it is one node driving both grippers and cannot emit a per-gripper
      // stream); see stream.rs.
      { name: "joint_commands", tag: "v1", link_id: "commands" },
      // Per-component readiness for the real robot_initializer.
      { name: "openarm_hardware_ready", tag: "v1", link_id: "ready" },
    ],
    depends_on: {
      pairings: [
        // The exclusive control conversation with ONE backbone instance:
        // streamed opening setpoints in, measured aperture back, both scoped
        // to the pair (no gripper_id demux). Optional: the gripper boots
        // unpaired (moves still work via backbone goals) and is paired at
        // the backbone's start.
        {
          name: "openarm_gripper_link",
          tag: "v1",
          role: "gripper",
          link_id: "backbone",
          optional: true,
        },
      ],
    },
  },
  execution: {
    language: "rust",
    container: {
      def_file: "apptainer.def"
    },
    parameters: {
      gripper_id: "u8",
      can_interface: "string",
      // Hardware-loop rate (Hz). Pick deliberately per deployment; the stack
      // currently unifies on 100 Hz across arms and grippers.
      control_rate_hz: "u32",
      // Per-cycle CAN read deadline (μs). Must fit the cycle budget (10 ms at 100 Hz).
      recv_timeout_us: { $type: "u32", $default: 1000 },
      // POS_FORCE absolute speed limit (rad/s at the motor). Default matches enactic's
      // reference (test_gripper_posforce).
      speed_rad_s: { $type: "f64", $default: 25.0 },
      // POS_FORCE torque-current limit (per-unit, 0..1): the grip-force cap the gripper
      // may apply. Default matches enactic's reference; raise for a firmer grip.
      force_limit_pu: { $type: "f64", $default: 0.15 },
      // Rate (Hz) of the always-on measured-opening streams (joint_states /
      // joint_commands); consumers' needs vary too much for a default to be
      // meaningful.
      state_rate_hz: "u32"
    }
  },
  interfaces: {
    topics: {
      emits: [
        { link_id: "states", name: "joint_states" },
        { link_id: "commands", name: "joint_commands" },
      ],
    },
    services: {
      exposes: [
        { link_id: "ready", name: "is_ready" },
      ],
    },
  },
}
