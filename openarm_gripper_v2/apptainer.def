Bootstrap: docker
From: tuatini/peppy-rust-cargo-base

%files
    . /opt/openarm_gripper_v2

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive

    apt-get update -y
    apt-get install -y --no-install-recommends software-properties-common
    add-apt-repository -y ppa:openarm/main
    apt-get update -y
    apt-get install -y --no-install-recommends libopenarm-can-dev

    cd /opt/openarm_gripper_v2
    cargo build --release

    apt-get clean && rm -rf /var/lib/apt/lists/*

%runscript
    cd /opt/openarm_gripper_v2
    exec ./target/release/openarm_gripper_v2 "$@"
