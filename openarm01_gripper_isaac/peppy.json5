// Isaac sim implementation of openarm01_gripper. Rust node that talks to a
// running Isaac sim via the raw peppylib JSON channel published by
// openarm01_robot_initializer_isaac — engine-internal coupling, not part of
// the openarm01_gripper:v1 interface contract. The gripper:v1 surface
// (move_gripper action, get_gripper_id service) is fully declared via
// conforms_to; topics.emits below are sim-only extras.
{
  peppy_schema: "node_v1",
  manifest: {
    name: "openarm01_gripper_isaac",
    tag: "v1",
    depends_on: {
      nodes: [
        { name: "openarm01_robot_initializer_isaac", tag: "v1", link_id: "sim" },
      ],
    },
  },
  interfaces: {
    conforms_to: [
      { name: "openarm01_gripper", tag: "v1" },
    ],
    // Engine-specific sim telemetry. Not part of openarm01_gripper:v1 — the
    // shared interface only exposes move_gripper + get_gripper_id (the cross-
    // impl contract). These emits exist because the sim has cheap access to
    // joint state, EE pose, and per-finger contacts; the real-hardware impl
    // doesn't have a force sensor per finger and reports gripper state through
    // its own channel. Topic names are flat (un-suffixed) because each gripper
    // instance owns one side, selected by the gripper_id execution parameter.
    topics: {
      emits: [
        {
          name: "gripper_state",
          qos_profile: "sensor_data",
          message_format: {
            robot: "string",
            step: "u64",
            joint_names: { $type: "array", $items: "string" },
            positions: { $type: "array", $items: "f64" },
            stamp: "f64",
          },
        },
        {
          name: "ee_pose",
          qos_profile: "sensor_data",
          message_format: {
            robot: "string",
            step: "u64",
            position: { $type: "array", $items: "f64", $length: 3 },
            orientation: { $type: "array", $items: "f64", $length: 4 },
            stamp: "f64",
          },
        },
        {
          name: "contact_forces_finger1",
          qos_profile: "sensor_data",
          message_format: {
            robot: "string",
            step: "u64",
            contacts: {
              $type: "array",
              $items: {
                $type: "object",
                body1: "string",
                body2: "string",
                position: { $type: "array", $items: "f64", $length: 3 },
                force: { $type: "array", $items: "f64", $length: 3 },
              },
            },
            stamp: "f64",
          },
        },
        {
          name: "contact_forces_finger2",
          qos_profile: "sensor_data",
          message_format: {
            robot: "string",
            step: "u64",
            contacts: {
              $type: "array",
              $items: {
                $type: "object",
                body1: "string",
                body2: "string",
                position: { $type: "array", $items: "f64", $length: 3 },
                force: { $type: "array", $items: "f64", $length: 3 },
              },
            },
            stamp: "f64",
          },
        },
      ],
    },
  },
  execution: {
    language: "rust",
    container: {
      def_file: "apptainer.def",
    },
    parameters: {
      // The gripper_id at runtime (0 = left, 1 = right). Two instances are
      // expected; the bin's file-lock + gripper_id guard rejects collisions.
      gripper_id: "u8",
    },
  },
}
