// Isaac sim implementation of openarm01_arm. Rust node that talks to a
// running Isaac Sim via the raw peppylib JSON channel published by
// openarm01_robot_initializer_isaac — engine-internal coupling, not part of
// the openarm01_arm:v1 interface contract. The arm:v1 surface
// (move_arm + move_arm_joints actions, get_arm_id + get_joint_positions
// services) is fully declared via conforms_to; topics.emits below are
// sim-only extras.
{
  peppy_schema: "node_v1",
  manifest: {
    name: "openarm01_arm_isaac",
    tag: "v1",
    depends_on: {
      nodes: [
        { name: "openarm01_robot_initializer_isaac", tag: "v1", link_id: "sim" },
      ],
    },
  },
  interfaces: {
    conforms_to: [
      { name: "openarm01_arm", tag: "v1" },
    ],
    // Engine-specific sim telemetry. Not part of openarm01_arm:v1 — the
    // shared interface only exposes move_arm + move_arm_joints + get_arm_id +
    // get_joint_positions (the cross-impl contract). These emits exist because
    // the sim has cheap access to joint state and the kinematic tf tree; the
    // real-hardware impl reports those through its own channel (CAN +
    // sensors) with a different shape. Topic names are flat (un-suffixed)
    // because each arm node instance owns one side, selected by the arm_id
    // execution parameter.
    topics: {
      emits: [
        {
          name: "joint_states",
          qos_profile: "sensor_data",
          message_format: {
            robot: "string",
            step: "u64",
            joint_names: { $type: "array", $items: "string" },
            positions: { $type: "array", $items: "f64" },
            velocities: { $type: "array", $items: "f64" },
            stamp: "f64",
          },
        },
        {
          name: "tf_tree",
          qos_profile: "sensor_data",
          message_format: {
            robot: "string",
            step: "u64",
            frames: {
              $type: "array",
              $items: {
                $type: "object",
                name: "string",
                parent: "string",
                position: { $type: "array", $items: "f64", $length: 3 },
                orientation: { $type: "array", $items: "f64", $length: 4 },
              },
            },
            stamp: "f64",
          },
        },
        // TODO: imu topic — declare here when robot_initializer_isaac's
        // bridge_extension publishes raw imu_<side>.
      ],
    },
  },
  execution: {
    language: "rust",
    container: {
      def_file: "apptainer.def",
    },
    parameters: {
      // The arm_id at runtime (0 = left, 1 = right). Two instances are
      // expected; the bin's file-lock + arm_id guard rejects collisions.
      arm_id: "u8",
    },
  },
}
