Bootstrap: docker
From: tuatini/peppy-rust-cargo-base:latest

%labels
    Name openarm01-arm-isaac
    Version v1

%files
    . /opt/openarm01_arm_isaac

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive

    cd /opt/openarm01_arm_isaac
    cargo build --release

%runscript
    cd /opt/openarm01_arm_isaac
    exec ./target/release/openarm01_arm_isaac "$@"
