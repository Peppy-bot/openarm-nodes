// One arm of the openarm robot (real hardware); instantiate twice, one per
// side, with a distinct `arm_id`. A follower of the bimanual hub: it owns the
// hardware control loop (gravity/Coriolis/friction feedforward from the
// in-process srs_model, plus MIT control) and tracks the hub's governed
// setpoint, reporting measured state on the always-on `arm_states` stream. The
// hub (openarm_backbone) owns all trajectory generation, stream following, and
// self-collision governing, so the arm carries no motion logic of its own.
{
  peppy_schema: "node/v1",
  manifest: {
    name: "openarm_arm",
    tag: "v1",
    depends_on: {
      interfaces: [
        // The hub's governed per-arm setpoint stream the arm tracks. Wildcard
        // (`from_any`): the backbone is the producer; this arm reads the entries
        // for its arm_id. Optional, so the arm boots and holds with no hub up.
        {
          name: "openarm_arm_governed_setpoints",
          tag: "v1",
          link_id: "hub",
          from_any: true,
        },
      ],
    },
  },
  execution: {
    language: "rust",
    container: {
      def_file: "apptainer.def"
    },
    parameters: {
      arm_id: "u8",
      can_interface: "string",
      // Which OpenArm hardware generation this arm drives: "v1" or "v2". Selects the
      // embedded description (URDF, joint limits, elbow margin) the in-process model is
      // built from. Required, not defaulted: running the wrong generation's model on the
      // hardware would mis-compensate gravity/Coriolis, so the launcher must be explicit.
      hardware_version: "string",
      // Link where this arm's SRS chain starts, selecting the side in the embedded
      // OpenArm description (openarm_description). v1: "openarm_left_link0"; v2:
      // "openarm_left_base_link" (v2 renamed the per-arm base link).
      base_link: "string",
      // Hardware-loop rate (Hz). Required: pick deliberately per deployment. The
      // stack currently unifies on 100 Hz (hub stream rate and arm loop rate match);
      // confirm `overruns=0` at the target rate during bring-up.
      control_rate_hz: "u32",
      // Per-cycle CAN read deadline (μs). Must fit the cycle budget (10 ms at 100 Hz).
      recv_timeout_us: { $type: "u32", $default: 1000 },
      // MIT-control gains applied every control tick, one per joint (1-indexed).
      // Match the openarm teleop config (Kp/Kd).
      kp1: { $type: "f64", $default: 240.0 },
      kp2: { $type: "f64", $default: 240.0 },
      kp3: { $type: "f64", $default: 240.0 },
      kp4: { $type: "f64", $default: 240.0 },
      kp5: { $type: "f64", $default: 24.0 },
      kp6: { $type: "f64", $default: 31.0 },
      kp7: { $type: "f64", $default: 25.0 },
      kd1: { $type: "f64", $default: 3.0 },
      kd2: { $type: "f64", $default: 3.0 },
      kd3: { $type: "f64", $default: 3.0 },
      kd4: { $type: "f64", $default: 3.0 },
      kd5: { $type: "f64", $default: 0.2 },
      kd6: { $type: "f64", $default: 0.2 },
      kd7: { $type: "f64", $default: 0.2 },
      // Rate (Hz) of the always-on measured-state stream (`arm_states`), which the
      // hub consumes. Required: consumers' needs vary too much for a default.
      state_rate_hz: "u32",
    }
  },
  interfaces: {
    conforms_to: [
      // Measured state for the hub (governor + trajectory anchor) and any monitor.
      {
        name: "openarm_arm_states",
        tag: "v1"
      },
      // Per-component readiness the real robot_initializer aggregates: ready once
      // motors are enabled and the control loop is serving.
      {
        name: "openarm_hardware_ready",
        tag: "v1"
      }
    ],
    topics: {
      consumes: [
        {
          name: "arm_governed_setpoints",
          link_id: "hub"
        }
      ],
    },
  },
}
