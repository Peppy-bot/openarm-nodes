Bootstrap: docker
From: tuatini/peppy-rust-cargo-base

%files
    . /opt/depth_camera

%post
    export DEBIAN_FRONTEND=noninteractive

    apt-get update -y
    apt-get install -y --no-install-recommends libclang-dev

    cd /opt/depth_camera
    cargo build --release

    apt-get clean && rm -rf /var/lib/apt/lists/*

%runscript
    cd /opt/depth_camera
    exec ./target/release/depth_camera "$@"
