Bootstrap: docker
From: jaredpeppy/openarm-isaac-sim:5.1.0-11

%labels
    Name openarm-robot-initializer-isaac
    Version v1

%environment
    export PYTHONPATH="/opt/isaac_robot_initializer/.peppy/libs/peppygen:/opt/isaac_robot_initializer/.peppy/libs/peppylib:$PYTHONPATH"
    export PEPPYGEN_OUTPUT_PATH="/opt/isaac_robot_initializer/.peppy/libs/peppygen"
    export PEPPY_BRIDGE_NODE_NAME=sim
    export PEPPY_BRIDGE_HEADLESS=${PEPPY_BRIDGE_HEADLESS:-1}
    export PEPPY_ISAAC_RENDERER=${PEPPY_ISAAC_RENDERER:-RayTracedLighting}
    export PEPPY_ROBOT_ASSETS_DIR=${PEPPY_ROBOT_ASSETS_DIR:-/opt/robot_assets/openarm/isaac}

%files
    peppy.json5 /opt/isaac_robot_initializer/peppy.json5
    robots /opt/isaac_robot_initializer/robots
    .peppy/libs/peppygen /opt/isaac_robot_initializer/.peppy/libs/peppygen
    .peppy/libs/peppylib /opt/isaac_robot_initializer/.peppy/libs/peppylib

%runscript
    cd /opt/isaac_robot_initializer
    exec /isaac-sim/python.sh /opt/isaac_robot_initializer/robots/openarm/openarm/launch.py "$@"
