Bootstrap: docker
From: peppybot/openarm-isaac-sim:5.1.0-17

%labels
    Name openarm-sim-isaac
    Version v1

%environment
    export PYTHONPATH="/opt/openarm_sim_isaac/.peppy/libs/peppygen:/opt/openarm_sim_isaac/.peppy/libs/peppylib:$PYTHONPATH"
    export PEPPYGEN_OUTPUT_PATH="/opt/openarm_sim_isaac/.peppy/libs/peppygen"
    export PEPPY_BRIDGE_NODE_NAME=sim
    export PEPPY_BRIDGE_HEADLESS=${PEPPY_BRIDGE_HEADLESS:-1}
    export PEPPY_ISAAC_RENDERER=${PEPPY_ISAAC_RENDERER:-RayTracedLighting}
    export PEPPY_ROBOT_ASSETS_DIR=${PEPPY_ROBOT_ASSETS_DIR:-/opt/robot_assets/openarm/isaac}

%files
    peppy.json5 /opt/openarm_sim_isaac/peppy.json5
    robots /opt/openarm_sim_isaac/robots
    .peppy/libs/peppygen /opt/openarm_sim_isaac/.peppy/libs/peppygen
    .peppy/libs/peppylib /opt/openarm_sim_isaac/.peppy/libs/peppylib

%runscript
    cd /opt/openarm_sim_isaac
    exec /isaac-sim/python.sh /opt/openarm_sim_isaac/robots/openarm/openarm/launch.py "$@"
