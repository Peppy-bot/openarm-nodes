// The Isaac Sim engine node. It
// plays the follower role of every limb's joint_link / gripper_link
// pairing: the sim relays lead each pair and the engine's measured state
// streams back on it. Sim peripherals attach to this node by node name for
// engine-internal coupling.
{
  peppy_schema: "node/v1",
  manifest: {
    name: "openarm_sim_isaac",
    tag: "v1",
    depends_on: {
      pairings: [
        // The engine plays the follower role of every limb's pairing directly,
        // one slot per limb (the slot is the side, so no id demux): governed
        // setpoints stream in, measured engine state streams back. Optional:
        // the engine boots unpaired and each pair is established at the
        // backbone's start (launcher `links:`).
        { name: "joint_link", tag: "v1", role: "follower", link_id: "left_arm", optional: true },
        { name: "joint_link", tag: "v1", role: "follower", link_id: "right_arm", optional: true },
        { name: "gripper_link", tag: "v1", role: "follower", link_id: "left_gripper", optional: true },
        { name: "gripper_link", tag: "v1", role: "follower", link_id: "right_gripper", optional: true },
      ],
    },
  },
  interfaces: {
    topics: {
      emits: [
        { link_id: "left_arm", name: "joint_states" },
        { link_id: "right_arm", name: "joint_states" },
        { link_id: "left_gripper", name: "gripper_states" },
        { link_id: "right_gripper", name: "gripper_states" },
      ],
      consumes: [
        { name: "joint_setpoints", link_id: "left_arm" },
        { name: "joint_setpoints", link_id: "right_arm" },
        { name: "gripper_setpoints", link_id: "left_gripper" },
        { name: "gripper_setpoints", link_id: "right_gripper" },
      ],
    },
  },
  execution: {
    language: "python",
    container: {
      def_file: "apptainer.def",
      apptainer_run_extra_args: ["--nv"],
      mount_paths: [
        "/run/user",
        "~/.cache/isaac-sim/kit/cache:/isaac-sim/kit/cache:rw",
        "~/.cache/isaac-sim/kit/data:/isaac-sim/kit/data:rw",
      ],
    },
    parameters: {
      // Which OpenArm generation to simulate: "v1" or "v2". Selects the scene file
      // (openarm_bimanual_{v1,v2}.usd) and the meshes materialized into the asset dir.
      // Required so the sim matches the real deployment it stands in for.
      hardware_version: "string",
      // Rate (Hz) of the measured-state streams (joint_states / gripper_states).
      state_rate_hz: "u32",
      // Run headless (the deployment default); set false to open the Isaac
      // viewer. Isaac's livestream host/port are handled by the streaming kit,
      // so there are no viewer_host/viewer_port params here (unlike mujoco).
      headless: { $type: "bool", $default: true },
    },
  },
}
