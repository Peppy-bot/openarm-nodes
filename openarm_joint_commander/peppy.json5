// openarm_joint_commander: operator entry point. Serves a browser-based
// control panel (HTTP + WebSocket on PEPPY_JC_PORT, default 8765) that streams
// operator arm and gripper setpoints to the hub (which governs and re-streams
// them) and fires move_arm_joints goals at openarm_backbone. MVP scope is
// slider-driven joint-space; pose_estimation will land as a sibling node.
{
  peppy_schema: "node/v1",
  manifest: {
    name: "openarm_joint_commander",
    tag: "v1",
    depends_on: {
      nodes: [
        // The hub; the commander fires its move_arm_joints action (the "Send"
        // button). Bound to the backbone instance in the launcher.
        {
          name: "openarm_backbone",
          tag: "v1",
          link_id: "backbone"
        }
      ],
      interfaces: [
        // Measured joint state of both arms, for live UI progress. Wildcard
        // (`from_any`) so the panel binds to whatever arms are running and tells
        // them apart by `arm_id`; optional, so the commander still boots with no
        // arm up. This replaces reading move progress off the action feedback.
        {
          name: "openarm_arm_states",
          tag: "v1",
          link_id: "arm_states",
          from_any: true
        },
        // Live nearest-pair self-collision distance + links from the hub, for the
        // proximity readout. Wildcard + optional like the state streams.
        {
          name: "openarm_collision_status",
          tag: "v1",
          link_id: "proximity",
          from_any: true
        },
        // Measured gripper opening of both grippers, for the live aperture
        // readout. Wildcard (`from_any`) + told apart by gripper_id, like
        // arm_states; the grippers stream this to the hub and the panel alike.
        {
          name: "openarm_gripper_states",
          tag: "v1",
          link_id: "gripper_states",
          from_any: true
        }
      ]
    }
  },
  interfaces: {
    // Streams operator setpoints to the hub: arm targets on arm_joint_commands and
    // gripper openings on gripper_commands, both told apart by id. Producing these
    // is what lets the panel drive an enabled arm/gripper continuously instead of
    // one move at a time; the hub governs each and re-streams the governed value,
    // so a follower clamps, rate-limits, and times out on its side.
    conforms_to: [
      {
        name: "openarm_arm_joint_commands",
        tag: "v1"
      },
      {
        name: "openarm_gripper_commands",
        tag: "v1"
      },
      // Runtime on/off for the hub's self-collision governor, driven by the UI
      // checkbox and re-published periodically (lossy QoS) so a dropped toggle
      // cannot strand the hub.
      {
        name: "openarm_governor_control",
        tag: "v1"
      }
    ],
    actions: {
      // Goals fired by the operator land on the hub, which runs the move itself
      // for the arm whose id matches arm_id.
      consumes: [
        {
          link_id: "backbone",
          name: "move_arm_joints"
        },
        // Cartesian point-to-point: Execute-pose in the panel's Actions mode fires
        // the hub's planned straight-line move rather than jogging there.
        {
          link_id: "backbone",
          name: "move_arm"
        },
        // Gripper open/close as a discrete governed action (Actions mode), rather
        // than the streamed opening used in Streaming mode.
        {
          link_id: "backbone",
          name: "move_gripper"
        }
      ]
    },
    topics: {
      consumes: [
        {
          name: "arm_states",
          link_id: "arm_states"
        },
        {
          name: "collision_status",
          link_id: "proximity"
        },
        {
          name: "gripper_states",
          link_id: "gripper_states"
        }
      ]
    }
  },
  execution: {
    language: "rust",
    container: {
      def_file: "apptainer.def"
    },
    parameters: {
      // Rate (Hz) at which enabled operator arm targets are re-published on
      // arm_joint_commands, which the backbone consumes. Must stay comfortably
      // above 1 / the backbone's stream_timeout_s so the producer lock survives
      // between operator inputs.
      command_rate_hz: "u32",
      // Robot generation ("v1" or "v2"): picks the panel joint + gripper ranges
      // (URDF limits + jaw width), so the launcher must be explicit.
      hardware_version: "string",
      // Operator's launch end-effector speed cap (m/s), streamed live to the hub on
      // governor_control and retunable from the UI. Require > 0. The sim launchers
      // set a permissive value; the real arm a conservative one.
      max_ee_velocity_m_s: "f64",
      // Launch state for the rest of the governor controls the operator streams live
      // on governor_control, set per deployment in step with openarm_backbone. The
      // band requires 0 < d_stop < d_safe.
      collision_governor_enabled: "bool",
      d_stop: "f64",
      d_safe: "f64"
    }
  }
}
