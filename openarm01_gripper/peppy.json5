// This node represents a single gripper in the openarm01 robot, the user will instanciate two different gripper, each with a different `gripper_id` input parameter.
// This is a root component node — openarm01_backbone depends on it, not the other way around.
// It is a "stupid" node that relays gripper commands from openarm01_backbone to either the real robot or the sims.
{
  peppy_schema: "node_v1",
  manifest: {
    name: "openarm01_gripper",
    tag: "0.1.0",
    variants: [
      // The real thing
      {
        name: "default",
        source: {
          local: "./variants/default"
        }
      },
      // The isaac sim variant
      {
        name: "isaac",
        source: {
          local: "./variants/isaac"
        }
      },
      // The mujoco variant
      {
        name: "mujoco",
        source: {
          local: "./variants/mujoco"
        }
      },
    ]
  },
  // Non exhaustive list of interfaces
  interfaces: {
    actions: {
      exposes: [
        {
          name: "move_gripper",
          goal_service: {
            request_message_format: {
              // The frequency in hertz at which the feedback is being sent
              feedback_frequency: "u32",
              // Target gripper opening in meters (0.0 = closed, 0.044 = fully open on V10).
              position: "f64"
            },
            response_message_format: {
              accepted: "bool"
            }
          },
          // Streamed as the gripper moves toward the goal
          feedback_topic: {
            qos_profile: "standard",
            message_format: {
              joint_positions: {
                $type: "array",
                $items: "f64"
              },
              action_time: "f64"
            }
          },
          result_service: {
            response_message_format: {
              success: "bool",
              message: "string",
              final_joint_positions: {
                $type: "array",
                $items: "f64"
              },
              action_time: "f64"
            }
          }
        }
      ]
    },
    services: {
      exposes: [
        {
          // Returns the runtime gripper_id set in `execution.parameters` (allows `openarm01_backbone` to differentiate between the grippers)
          name: "get_gripper_id",
          response_message_format: {
            gripper_id: "u8"
          }
        }
      ]
    },
    topics: {
      emits: [
        {
          name: "gripper_state_left",
          qos_profile: "sensor_data",
          message_format: {
            robot:       "string",
            step:        "u64",
            joint_names: { $type: "array", $items: "string" },
            positions:   { $type: "array", $items: "f64" },
            stamp:       "f64",
          },
        },
        {
          name: "gripper_state_right",
          qos_profile: "sensor_data",
          message_format: {
            robot:       "string",
            step:        "u64",
            joint_names: { $type: "array", $items: "string" },
            positions:   { $type: "array", $items: "f64" },
            stamp:       "f64",
          },
        },
        {
          name: "ee_pose_left",
          qos_profile: "sensor_data",
          message_format: {
            robot:       "string",
            step:        "u64",
            position:    { $type: "array", $items: "f64", $length: 3 },
            orientation: { $type: "array", $items: "f64", $length: 4 },
            stamp:       "f64",
          },
        },
        {
          name: "ee_pose_right",
          qos_profile: "sensor_data",
          message_format: {
            robot:       "string",
            step:        "u64",
            position:    { $type: "array", $items: "f64", $length: 3 },
            orientation: { $type: "array", $items: "f64", $length: 4 },
            stamp:       "f64",
          },
        },
        // Convention for the four contact_forces_*_finger{1,2} topics:
        //   finger1 = right-side finger geom of the gripper (in its own frame).
        //   finger2 = left-side  finger geom of the gripper.
        // Stable across both grippers — contact_forces_left_finger1 carries
        // contacts on the right finger of the LEFT gripper.
        {
          name: "contact_forces_left_finger1",
          qos_profile: "sensor_data",
          message_format: {
            robot: "string",
            step:  "u64",
            contacts: {
              $type: "array",
              $items: {
                $type:    "object",
                body1:    "string",
                body2:    "string",
                position: { $type: "array", $items: "f64", $length: 3 },
                force:    { $type: "array", $items: "f64", $length: 3 },
              },
            },
            stamp: "f64",
          },
        },
        {
          name: "contact_forces_left_finger2",
          qos_profile: "sensor_data",
          message_format: {
            robot: "string",
            step:  "u64",
            contacts: {
              $type: "array",
              $items: {
                $type:    "object",
                body1:    "string",
                body2:    "string",
                position: { $type: "array", $items: "f64", $length: 3 },
                force:    { $type: "array", $items: "f64", $length: 3 },
              },
            },
            stamp: "f64",
          },
        },
        {
          name: "contact_forces_right_finger1",
          qos_profile: "sensor_data",
          message_format: {
            robot: "string",
            step:  "u64",
            contacts: {
              $type: "array",
              $items: {
                $type:    "object",
                body1:    "string",
                body2:    "string",
                position: { $type: "array", $items: "f64", $length: 3 },
                force:    { $type: "array", $items: "f64", $length: 3 },
              },
            },
            stamp: "f64",
          },
        },
        {
          name: "contact_forces_right_finger2",
          qos_profile: "sensor_data",
          message_format: {
            robot: "string",
            step:  "u64",
            contacts: {
              $type: "array",
              $items: {
                $type:    "object",
                body1:    "string",
                body2:    "string",
                position: { $type: "array", $items: "f64", $length: 3 },
                force:    { $type: "array", $items: "f64", $length: 3 },
              },
            },
            stamp: "f64",
          },
        },
      ],
    },
  },
}