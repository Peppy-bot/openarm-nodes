// This node represents a single gripper in the openarm01 robot, the user will instanciate two different gripper, each with a different `gripper_id` input parameter.
// This is a root component node — openarm01_backbone depends on it, not the other way around.
// It is a "stupid" node that relays gripper commands from openarm01_backbone to either the real robot or the sims.
{
  peppy_schema: "node_v1",
  manifest: {
    name: "openarm01_gripper",
    tag: "v1"
  },
  execution: {
    language: "rust",
    container: {
      def_file: "apptainer.def"
    },
    parameters: {
      gripper_id: "u8",
      can_interface: "string",
      // Hardware-loop rate (Hz). Required: pick deliberately per deployment
      // (the OpenArm teleop reference drives the gripper in the same 500 Hz
      // loop as the arm).
      control_rate_hz: "u32",
      // Per-cycle CAN read deadline (μs). Must fit the cycle budget (2 ms at 500 Hz).
      recv_timeout_us: { $type: "u32", $default: 1000 },
      // Error threshold (m) for goal completion.
      position_tolerance: { $type: "f64", $default: 0.001 },
      motion_timeout_s: { $type: "f64", $default: 10.0 },
      // Rate (Hz) of the always-on measured-opening stream (`gripper_states`).
      // Required: consumers' needs vary too much for a default to be meaningful.
      state_rate_hz: "u32"
    }
  },
  interfaces: {
    conforms_to: [
      {
        name: "openarm01_gripper",
        tag: "v1"
      },
      // Always-on measured opening, mirroring the arm's joint_state_source so
      // teleop/monitoring consume sim and real grippers identically (by gripper_id).
      {
        name: "openarm01_gripper_state_source",
        tag: "v1"
      }
    ]
  },
}
