// Single gripper of the OpenArm01 robot. Two instances are deployed — one per arm —
// each configured with a distinct gripper_id at start time.
// ROOT node: no depends_on. Backbone depends on this node, not the reverse.
{
  schema_version: 1,
  manifest: {
    name: "openarm01_gripper",
    tag: "0.1.0",
    variants: [
      { name: "default", source: { local: "./variants/default" } },
      { name: "mujoco",  source: { local: "./variants/mujoco"  } },
      { name: "isaac",   source: { local: "./variants/isaac"   } },
    ]
  },
  interfaces: {
    actions: {
      exposes: [
        {
          name: "move_gripper",
          goal_service: {
            request_message_format: {
              feedback_frequency: "u32",
              // OpenArm01 gripper has 3 independently controllable finger DOFs.
              // IsaacGripperCommand / MujocoGripperCommand must be configured with
              // exactly 3 entries in finger_joints to match this contract.
              desired_position: {
                $type: "array",
                $items: "f64",
                $length: 3
              }
            },
            response_message_format: {
              accepted: "bool"
            }
          },
          feedback_topic: {
            qos_profile: "standard",
            message_format: {
              joint_positions: { $type: "array", $items: "f64" },
              action_time: "f64"
            }
          },
          result_service: {
            response_message_format: {
              success: "bool",
              message: "string",
              final_joint_positions: { $type: "array", $items: "f64" },
              action_time: "f64"
            }
          }
        }
      ]
    },
    services: {
      exposes: [
        {
          name: "get_gripper_id",
          response_message_format: {
            gripper_id: "u8"
          }
        }
      ]
    }
  }
}
