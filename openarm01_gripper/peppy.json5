// ROOT node — owns sim/real abstraction for the gripper.
// 2 instances at runtime: left_gripper (gripper_id=0), right_gripper (gripper_id=1).
// gripper_id lives in execution.parameters — set per instance in the launcher.
// Owns end-effector telemetry: ee_pose, gripper_state, contact_forces.
{
  peppy_schema: "node_v1",
  manifest: {
    name: "openarm01_gripper",
    tag: "0.1.0",
    variants: [
      { name: "default", source: { local: "./variants/default" } },
      { name: "isaac",   source: { local: "./variants/isaac"   } },
      { name: "mujoco",  source: { local: "./variants/mujoco"  } },
    ],
  },
  interfaces: {
    actions: {
      exposes: [
        {
          name: "move_gripper",
          goal_service: {
            request_message_format: {
              feedback_frequency: "u32",
              position:           "f64",  // meters — 0.0 closed, 0.044 fully open (V10)
            },
            response_message_format: {
              accepted: "bool",
            },
          },
          feedback_topic: {
            qos_profile: "sensor_data",
            message_format: {
              joint_positions: { $type: "array", $items: "f64" },
              action_time:     "f64",
            },
          },
          result_service: {
            response_message_format: {
              success:               "bool",
              message:               "string",
              final_joint_positions: { $type: "array", $items: "f64" },
              action_time:           "f64",
            },
          },
        },
      ],
    },
    services: {
      exposes: [
        {
          name: "get_gripper_id",
          response_message_format: {
            gripper_id: "u8",
          },
        },
      ],
    },
    topics: {
      emits: [
        {
          name: "ee_pose_left",
          qos_profile: "sensor_data",
          message_format: {
            robot:       "string",
            step:        "u64",
            position:    { $type: "array", $items: "f64", $length: 3 },
            orientation: { $type: "array", $items: "f64", $length: 4 },
            stamp:       "f64",
          },
        },
        {
          name: "ee_pose_right",
          qos_profile: "sensor_data",
          message_format: {
            robot:       "string",
            step:        "u64",
            position:    { $type: "array", $items: "f64", $length: 3 },
            orientation: { $type: "array", $items: "f64", $length: 4 },
            stamp:       "f64",
          },
        },
        {
          name: "gripper_state_left",
          qos_profile: "sensor_data",
          message_format: {
            robot:          "string",
            step:           "u64",
            joint_names:    { $type: "array", $items: "string" },
            positions:      { $type: "array", $items: "f64" },
            stamp:          "f64",
          },
        },
        {
          name: "gripper_state_right",
          qos_profile: "sensor_data",
          message_format: {
            robot:          "string",
            step:           "u64",
            joint_names:    { $type: "array", $items: "string" },
            positions:      { $type: "array", $items: "f64" },
            stamp:          "f64",
          },
        },
        // Convention for the four contact_forces_*_finger{1,2} topics:
        //   finger1 = right-side finger geom of the gripper (in the gripper's own frame).
        //   finger2 = left-side  finger geom of the gripper.
        // Stable across both grippers - i.e. contact_forces_left_finger1 carries
        // contacts on the right finger of the LEFT gripper.
        {
          name: "contact_forces_left_finger1",
          qos_profile: "sensor_data",
          message_format: {
            robot: "string",
            step:  "u64",
            contacts: {
              $type: "array",
              $items: {
                $type:    "object",
                body1:    "string",
                body2:    "string",
                position: { $type: "array", $items: "f64", $length: 3 },
                force:    { $type: "array", $items: "f64", $length: 3 },
              },
            },
            stamp: "f64",
          },
        },
        {
          name: "contact_forces_left_finger2",
          qos_profile: "sensor_data",
          message_format: {
            robot: "string",
            step:  "u64",
            contacts: {
              $type: "array",
              $items: {
                $type:    "object",
                body1:    "string",
                body2:    "string",
                position: { $type: "array", $items: "f64", $length: 3 },
                force:    { $type: "array", $items: "f64", $length: 3 },
              },
            },
            stamp: "f64",
          },
        },
        {
          name: "contact_forces_right_finger1",
          qos_profile: "sensor_data",
          message_format: {
            robot: "string",
            step:  "u64",
            contacts: {
              $type: "array",
              $items: {
                $type:    "object",
                body1:    "string",
                body2:    "string",
                position: { $type: "array", $items: "f64", $length: 3 },
                force:    { $type: "array", $items: "f64", $length: 3 },
              },
            },
            stamp: "f64",
          },
        },
        {
          name: "contact_forces_right_finger2",
          qos_profile: "sensor_data",
          message_format: {
            robot: "string",
            step:  "u64",
            contacts: {
              $type: "array",
              $items: {
                $type:    "object",
                body1:    "string",
                body2:    "string",
                position: { $type: "array", $items: "f64", $length: 3 },
                force:    { $type: "array", $items: "f64", $length: 3 },
              },
            },
            stamp: "f64",
          },
        },
      ],
    },
  },
}
