Bootstrap: docker
From: tuatini/peppy-rust-cargo-base:latest

%labels
    Name openarm01-gripper-isaac
    Version 0.1.0

%files
    . /opt/openarm01_gripper_isaac

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive

    cd /opt/openarm01_gripper_isaac
    cargo build --release

%runscript
    cd /opt/openarm01_gripper_isaac
    exec ./target/release/openarm01_gripper "$@"
