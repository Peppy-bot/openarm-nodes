Bootstrap: docker
From: aaqibmahamood/openarm01-mujoco-sim:3.8.1

%labels
    Name openarm01-robot-initializer-mujoco
    Version 0.1.0

%environment
    export PYTHONPATH="/opt/mujoco_robot_initializer/.peppy/libs/peppygen:$HOME/.peppy/libs/python:$PYTHONPATH"
    export PEPPYGEN_OUTPUT_PATH="/opt/mujoco_robot_initializer/.peppy/libs/peppygen"
    export PEPPY_BRIDGE_HEADLESS=${PEPPY_BRIDGE_HEADLESS:-1}
    export PEPPY_BRIDGE_NODE_NAME=sim
    export MUJOCO_GL=${MUJOCO_GL:-egl}
    export WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-}
    export XDG_RUNTIME_DIR=${XDG_RUNTIME_DIR:-/run/user/$(id -u)}
    export DISPLAY=${DISPLAY:-}
    export PEPPY_ROBOT_ASSETS_DIR=${PEPPY_ROBOT_ASSETS_DIR:-/opt/robot_assets/openarm/mujoco}
    # Mjdata bus directory. Uses $XDG_RUNTIME_DIR (/run/user/$UID), which
    # peppy already bind-mounts into the container. Per-user isolation, not
    # per-stack — proper per-stack tmpfs support is pending a peppy
    # stack-manager feature.
    export PEPPY_MJDATA_BUS_DIR=${PEPPY_MJDATA_BUS_DIR:-/run/user/$(id -u)/peppy/sim}

%files
    peppy.json5 /opt/mujoco_robot_initializer/peppy.json5
    robots /opt/mujoco_robot_initializer/robots
    .peppy/libs/peppygen /opt/mujoco_robot_initializer/.peppy/libs/peppygen

%runscript
    cd /opt/mujoco_robot_initializer
    mkdir -p "$PEPPY_MJDATA_BUS_DIR"
    exec python3 /opt/mujoco_robot_initializer/robots/openarm/openarm/launch.py "$@"
