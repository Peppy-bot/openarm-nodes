Bootstrap: docker
From: aaqibmahamood/openarm01-mujoco-sim:0.1.0

%labels
    Name openarm01-robot-initializer-mujoco
    Version 0.1.0

%environment
    export PYTHONPATH="/opt/mujoco_robot_initializer/.peppy/libs/peppygen:$HOME/.peppy/libs/python:$PYTHONPATH"
    export PEPPY_BRIDGE_HEADLESS=${PEPPY_BRIDGE_HEADLESS:-1}
    export PEPPY_BRIDGE_NODE_NAME=sim
    export WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-wayland-0}
    export XDG_RUNTIME_DIR=${XDG_RUNTIME_DIR:-/run/user/$(id -u)}
    export DISPLAY=
    export PEPPY_ROBOT_ASSETS_DIR=${PEPPY_ROBOT_ASSETS_DIR:-/opt/robot_assets/openarm/mujoco}

%files

%runscript
    cd /opt/mujoco_robot_initializer
    exec python3 /opt/mujoco_robot_initializer/robots/openarm/openarm/launch.py "$@"
