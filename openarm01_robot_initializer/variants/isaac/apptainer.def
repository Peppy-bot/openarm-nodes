Bootstrap: docker
From: aaqibmahamood/openarm01-isaac-sim:5.1.0

%labels
    Name openarm01-robot-initializer-isaac
    Version 0.1.0

%environment
    export PYTHONPATH="/opt/isaac_robot_initializer/.peppy/libs/peppygen:$HOME/.peppy/libs/python:$PYTHONPATH"
    export PEPPY_BRIDGE_NODE_NAME=sim
    export PEPPY_BRIDGE_HEADLESS=${PEPPY_BRIDGE_HEADLESS:-1}
    export PEPPY_ISAAC_RENDERER=${PEPPY_ISAAC_RENDERER:-RayTracedLighting}
    export DISPLAY=${DISPLAY:-:1}
    export PEPPY_ROBOT_ASSETS_DIR=${PEPPY_ROBOT_ASSETS_DIR:-/opt/robot_assets/openarm/isaac}

%files

%runscript
    cd /isaac-sim
    exec ./python.sh /opt/isaac_robot_initializer/robots/openarm/openarm/launch.py "$@"
