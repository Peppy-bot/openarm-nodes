Bootstrap: docker
From: tuatini/peppy-rust-cargo-base:latest

%labels
    Name openarm01_robot_initializer
    Version 0.1.0

%files
    . /opt/openarm01_robot_initializer

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive

    cd /opt/openarm01_robot_initializer
    cargo build --release

%runscript
    cd /opt/openarm01_robot_initializer
    exec ./target/release/openarm01_robot_initializer
