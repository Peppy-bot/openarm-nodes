// Bridge plugin registry for the MuJoCo openarm scene. Per-side suffix
// (`<topic>_left` / `<topic>_right`) lines up with the typed peppygen topic
// names on the gripper/arm Rust side.
{
  // Publishers emit raw peppylib JSON each tick.
  publishers: [
    // Whole-robot joint state. Consumers slice by joint name on their side.
    { type: "joint_states", topic: "joint_states", robot_name: "openarm" },

    // Whole-world TF tree. Consumers walk frames they care about.
    { type: "tf_tree", topic: "tf_tree", robot_name: "openarm" },

    // Whole-world contacts. Consumers filter by their own geom IDs.
    { type: "contact_forces", topic: "contact_forces", robot_name: "openarm" },

    // Per-side gripper finger joints (positions + measured actuator forces).
    {
      type: "gripper_state", topic: "gripper_state_left", robot_name: "openarm",
      params: { finger_joints: ["openarm_left_finger_joint1", "openarm_left_finger_joint2"] },
    },
    {
      type: "gripper_state", topic: "gripper_state_right", robot_name: "openarm",
      params: { finger_joints: ["openarm_right_finger_joint1", "openarm_right_finger_joint2"] },
    },

    // Per-side end-effector pose (TCP body).
    { type: "ee_pose", prim: "openarm_left_hand_tcp",  topic: "ee_pose_left",  robot_name: "openarm" },
    { type: "ee_pose", prim: "openarm_right_hand_tcp", topic: "ee_pose_right", robot_name: "openarm" },

    // IMU publishers: uncomment once the MJCF declares the IMU bodies.
    // { type: "imu", prim: "openarm_left_imu",  topic: "imu_left",  robot_name: "openarm" },
    // { type: "imu", prim: "openarm_right_imu", topic: "imu_right", robot_name: "openarm" },
  ],

  // Subscribers drain latest before mj_step. Topic: set_ctrl_<component>_<side>
  // with payload { actuator_values: { <name>: <value>, ... } }.
  subscribers: [
    { type: "actuator_ctrl", topic: "set_ctrl_gripper_left",  source_node: "openarm01_gripper" },
    { type: "actuator_ctrl", topic: "set_ctrl_gripper_right", source_node: "openarm01_gripper" },

    // Arm subscribers — MujocoActuatorCtrl indexes by both actuator name AND
    // joint name (via actuator_trnid walk), letting the arm runtime send the
    // canonical joint name `openarm_<side>_joint{1..7}` and resolve on both engines.
    { type: "actuator_ctrl", topic: "set_ctrl_arm_left",  source_node: "openarm01_arm" },
    { type: "actuator_ctrl", topic: "set_ctrl_arm_right", source_node: "openarm01_arm" },
  ],
}
