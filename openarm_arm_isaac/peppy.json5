// Isaac sim follower for one openarm arm. A thin bridge: it follows the backbone's
// governed setpoints over the arm_link pairing (collision-governed,
// rate-limited, the backbone owns all trajectory generation) and republishes the
// resolved (q_des, dq_des) on the sim-internal arm_sim_passthrough topic for
// the engine to actuate, relaying the engine's measured state back to the
// paired backbone. No trajectory, follow, or collision logic of its own - that all
// lives in openarm_backbone, so the sim and the real arm follow the same
// governed stream. Two instances, one per side.
{
  peppy_schema: "node/v1",
  manifest: {
    name: "openarm_arm_isaac",
    tag: "v1",
    implements: [
      // The resolved joint setpoint handed to the sim engine (sim-internal passthrough).
      { name: "openarm_arm_sim_passthrough", tag: "v1", link_id: "sim_passthrough" },
      // This arm's measured state on the generic joint_states contract, re-emitted
      // per side from the engine's broadcast so a recorder or monitor binds this
      // follower exactly like the real arm.
      { name: "joint_states", tag: "v1", link_id: "states" },
      // The governed setpoint commanded to this arm on the generic joint_commands
      // contract, so a recorder captures the action aligned with joint_states.
      // Per-arm here (the backbone that computes it is one node driving both arms
      // and cannot emit a per-arm stream), matching the real arm.
      { name: "joint_commands", tag: "v1", link_id: "commands" },
    ],
    depends_on: {
      pairings: [
        // The exclusive command loop with the backbone: governed setpoints stream in
        // and the engine's measured state is relayed back, both scoped to the
        // pair (no arm_id demux). Optional: the follower boots and idles with no
        // backbone paired; the pair is established at the backbone's start.
        {
          name: "openarm_arm_link",
          tag: "v1",
          role: "arm",
          link_id: "backbone",
          optional: true,
        },
      ],
      contracts: [
        // Measured joint state from the sim engine, demuxed by arm_id and relayed
        // to the paired backbone and the per-side joint_states re-emit. This is
        // the one place arm_id is still load-bearing: the engine is a single
        // producer for both arms, which no generic per-side contract can express.
        // Bound to the sim instance at launch.
        {
          name: "openarm_arm_states",
          tag: "v1",
          link_id: "engine_states",
        },
      ],
    },
  },
  interfaces: {
    topics: {
      emits: [
        { link_id: "sim_passthrough", name: "arm_sim_passthrough" },
        { link_id: "states", name: "joint_states" },
        { link_id: "commands", name: "joint_commands" },
      ],
      consumes: [
        { name: "arm_states", link_id: "engine_states" },
      ],
    },
  },
  execution: {
    language: "rust",
    container: {
      def_file: "apptainer.def",
    },
    parameters: {
      // The arm_id at runtime (0 = left, 1 = right): selects which engine state
      // entries to relay and tags the passthrough for the engine.
      arm_id: "u8",
    },
  },
}
