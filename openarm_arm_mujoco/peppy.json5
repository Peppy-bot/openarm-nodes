// MuJoCo sim follower for one openarm arm. A thin bridge: it follows the hub's
// governed setpoints over the arm_link pairing (collision-governed,
// rate-limited, the hub owns all trajectory generation) and republishes the
// resolved (q_des, dq_des) on the sim-internal arm_sim_passthrough topic for
// the engine to actuate, relaying the engine's measured state back to the
// paired hub. No trajectory, follow, or collision logic of its own - that all
// lives in openarm_backbone, so the sim and the real arm follow the same
// governed stream. Two instances, one per side.
{
  peppy_schema: "node/v1",
  manifest: {
    name: "openarm_arm_mujoco",
    tag: "v1",
    depends_on: {
      pairings: [
        // The exclusive command loop with the hub: governed setpoints stream in
        // and the engine's measured state is relayed back, both scoped to the
        // pair (no arm_id demux). Optional: the follower boots and idles with no
        // hub paired; the pair is established at the hub's start.
        {
          name: "openarm_arm_link",
          tag: "v1",
          role: "arm",
          link_id: "hub",
          optional: true,
        },
      ],
      contracts: [
        // Measured joint state from the sim engine, relayed to the paired hub.
        // Bound to the sim instance at launch; entries told apart by arm_id.
        {
          name: "openarm_arm_states",
          tag: "v1",
          link_id: "state",
        },
      ],
    },
  },
  interfaces: {
    conforms_to: [
      // The resolved joint setpoint handed to the sim engine (sim-internal passthrough).
      { name: "openarm_arm_sim_passthrough", tag: "v1" },
    ],
    topics: {
      consumes: [
        { name: "arm_states", link_id: "state" },
      ],
    },
  },
  execution: {
    language: "rust",
    container: {
      def_file: "apptainer.def",
    },
    parameters: {
      // The arm_id at runtime (0 = left, 1 = right): selects which engine state
      // entries to relay and tags the passthrough for the engine.
      arm_id: "u8",
    },
  },
}
