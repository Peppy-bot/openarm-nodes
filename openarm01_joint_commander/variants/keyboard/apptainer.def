Bootstrap: docker
From: tuatini/peppy-rust-cargo-base:latest

%labels
    Name joint_commander
    Version 0.1.0

%environment
    export PATH="/root/.cargo/bin:$PATH"

%files
    . /opt/joint_commander

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive
    apt-get -o Acquire::Retries=5 -o Acquire::ForceIPv4=true update \
    && apt-get -o Acquire::Retries=5 -o Acquire::ForceIPv4=true install -y --no-install-recommends \
        ca-certificates curl build-essential pkg-config libssl-dev
    rm -rf /var/lib/apt/lists/*
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
    export PATH="/root/.cargo/bin:$PATH"
    cd /opt/joint_commander
    cargo build --release

%runscript
    cd /opt/joint_commander
    exec ./target/release/joint_commander "$@"
