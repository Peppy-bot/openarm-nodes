// openarm01_joint_commander: operator entry point. Serves a browser-based
// control panel (HTTP + WebSocket on PEPPY_JC_PORT, default 8765) that streams
// operator setpoints to the arms and grippers and fires move_arm_joints goals at
// openarm01_backbone. MVP scope is slider-driven joint-space; pose_estimation
// will land as a sibling node.
{
  peppy_schema: "node/v1",
  manifest: {
    name: "openarm01_joint_commander",
    tag: "v1",
    depends_on: {
      // backbone has no variants and is not a conforming impl of any interface,
      // so the dep is by node identity, not by interface.
      nodes: [
        {
          name: "openarm01_backbone",
          tag: "v1",
          link_id: "backbone"
        }
      ],
      interfaces: [
        // Measured joint state of both arms, for live UI progress. Wildcard
        // (`from_any`) so the panel binds to whatever arms are running and tells
        // them apart by `arm_id`; optional, so the commander still boots with no
        // arm up. This replaces reading move progress off the action feedback.
        {
          name: "openarm01_joint_state_source",
          tag: "v1",
          link_id: "arm_states",
          from_any: true
        },
        // Measured opening of both grippers, for live UI progress. Same wildcard
        // optional pattern as the arms; told apart by `gripper_id`. Replaces
        // reading gripper move progress off the action feedback.
        {
          name: "openarm01_gripper_state_source",
          tag: "v1",
          link_id: "gripper_states",
          from_any: true
        }
      ]
    }
  },
  interfaces: {
    // Streams operator setpoints to the arms (joint_commands) and grippers
    // (gripper_commands). Producing these is what lets the panel drive an enabled
    // arm/gripper continuously instead of one move at a time; each node clamps,
    // rate-limits, and times out the stream on its side.
    conforms_to: [
      {
        name: "openarm01_joint_command_source",
        tag: "v1"
      },
      {
        name: "openarm01_gripper_command_source",
        tag: "v1"
      }
    ],
    actions: {
      // Goals fired by the operator land on backbone, which forwards to the
      // arm / gripper instance whose id matches arm_id / gripper_id.
      consumes: [
        {
          link_id: "backbone",
          name: "move_arm_joints"
        }
      ]
    },
    topics: {
      consumes: [
        {
          name: "joint_states",
          link_id: "arm_states"
        },
        {
          name: "gripper_states",
          link_id: "gripper_states"
        }
      ]
    }
  },
  execution: {
    language: "rust",
    container: {
      def_file: "apptainer.def"
    },
    parameters: {
      // Rate (Hz) at which an armed arm's target setpoint is re-published on
      // joint_commands. Must stay comfortably above 1 / the arm's stream_timeout_s
      // so the producer lock survives between operator inputs.
      command_rate_hz: { $type: "u32", $default: 100 }
    }
  }
}
