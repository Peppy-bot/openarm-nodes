// openarm01_joint_commander — operator entry point. Serves a browser-based
// control panel (HTTP + WebSocket on PEPPY_JC_PORT, default 8765) that fires
// move_arm_joints / move_gripper goals at openarm01_backbone. MVP scope is
// slider-driven joint-space; pose_estimation will land as a sibling node.
{
  peppy_schema: "node_v1",
  manifest: {
    name: "openarm01_joint_commander",
    tag: "v1",
    depends_on: {
      // backbone has no variants and is not a conforming impl of any interface,
      // so the dep is by node identity, not by interface.
      nodes: [
        {
          name: "openarm01_backbone",
          tag: "v1",
          link_id: "backbone"
        }
      ]
    }
  },
  interfaces: {
    actions: {
      // Goals fired by the operator land on backbone, which forwards to the
      // arm / gripper instance whose id matches arm_id / gripper_id.
      consumes: [
        {
          link_id: "backbone",
          name: "move_arm_joints"
        },
        {
          link_id: "backbone",
          name: "move_gripper"
        }
      ]
    }
  },
  execution: {
    language: "rust",
    container: {
      def_file: "apptainer.def"
    }
  }
}
