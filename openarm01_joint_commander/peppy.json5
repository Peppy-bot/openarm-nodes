// openarm01_joint_commander — operator entry point. Reads keyboard input,
// shows arm + gripper state in a TUI, and fires move_arm_joints / move_gripper
// goals at openarm01_backbone. Backbone routes each goal to the correct
// arm / gripper instance.
//
// MVP scope: keyboard variant only, joint-space. Cartesian + pose_estimation
// variant are post-MVP and not declared here yet.
{
  peppy_schema: "node_v1",
  manifest: {
    name: "openarm01_joint_commander",
    tag: "0.1.0",
    depends_on: {
      nodes: [
        {
          name: "openarm01_backbone",
          tag: "0.1.0",
          local_id: "backbone"
        }
      ]
    },
    variants: [
      // Default variant is the keyboard TUI. Operator steps joints, then
      // hits Enter to fire a goal at backbone. pose_estimation variant
      // comes post-MVP.
      {
        name: "default",
        source: {
          local: "./variants/keyboard"
        }
      }
    ]
  },
  interfaces: {
    actions: {
      // Goals fired by the operator land on backbone, which forwards to the
      // arm / gripper instance whose id matches arm_id / gripper_id.
      consumes: [
        {
          local_node_id: "backbone",
          name: "move_arm_joints"
        },
        {
          local_node_id: "backbone",
          name: "move_gripper"
        }
      ]
    }
  }
}
