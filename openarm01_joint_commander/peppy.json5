// openarm01_joint_commander: operator entry point. Serves a browser-based
// control panel (HTTP + WebSocket on PEPPY_JC_PORT, default 8765) that streams
// operator setpoints to the arms and grippers and fires move_arm_joints goals at
// openarm01_backbone. MVP scope is slider-driven joint-space; pose_estimation
// will land as a sibling node.
{
  peppy_schema: "node/v1",
  manifest: {
    name: "openarm01_joint_commander",
    tag: "v1",
    depends_on: {
      // backbone has no variants and is not a conforming impl of any interface,
      // so the dep is by node identity, not by interface.
      nodes: [
        {
          name: "openarm01_backbone",
          tag: "v1",
          link_id: "backbone"
        }
      ],
      pairings: [
        // One pairing slot per driven component: each holds exactly one paired
        // peer, so setpoints and measured state are scoped per slot with no
        // arm_id / gripper_id demux. All optional: the panel boots with any
        // subset unpaired (those sliders just stay inert) and each pair is
        // established at this instance's start (`--pair left_arm@<arm_inst>` /
        // launcher `pairings:`).
        {
          name: "openarm01_arm_joint_link",
          tag: "v1",
          role: "commander",
          link_id: "left_arm",
          optional: true
        },
        {
          name: "openarm01_arm_joint_link",
          tag: "v1",
          role: "commander",
          link_id: "right_arm",
          optional: true
        },
        {
          name: "openarm01_gripper_link",
          tag: "v1",
          role: "commander",
          link_id: "left_gripper",
          optional: true
        },
        {
          name: "openarm01_gripper_link",
          tag: "v1",
          role: "commander",
          link_id: "right_gripper",
          optional: true
        }
      ]
    }
  },
  interfaces: {
    actions: {
      // Goals fired by the operator land on backbone, which forwards to the
      // arm / gripper instance whose id matches arm_id / gripper_id.
      consumes: [
        {
          link_id: "backbone",
          name: "move_arm_joints"
        }
      ]
    },
  },
  execution: {
    language: "rust",
    container: {
      def_file: "apptainer.def"
    },
    parameters: {
      // Rate (Hz) at which an armed arm's target setpoint is re-published on
      // joint_commands. Must stay comfortably above 1 / the arm's stream_timeout_s
      // so the producer lock survives between operator inputs.
      command_rate_hz: { $type: "u32", $default: 100 }
    }
  }
}
