Bootstrap: docker
From: tuatini/peppy-rust-cargo-base:latest

%labels
    Name openarm01-arm-mujoco
    Version v1

%files
    . /opt/openarm01_arm_mujoco

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive

    cd /opt/openarm01_arm_mujoco
    cargo build --release

%runscript
    cd /opt/openarm01_arm_mujoco
    exec ./target/release/openarm01_arm_mujoco "$@"
