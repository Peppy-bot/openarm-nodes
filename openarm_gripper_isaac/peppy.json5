// Isaac sim implementation of openarm_gripper. Follows streamed
// gripper_commands and emits the resolved aperture on gripper_sim_passthrough for
// the sim to actuate; relays the sim's gripper_states to the paired backbone.
// Typed peppygen topics throughout, no raw peppylib.
{
  peppy_schema: "node/v1",
  manifest: {
    name: "openarm_gripper_isaac",
    tag: "v1",
    implements: [
      // The resolved aperture handed to the sim engine (sim-internal passthrough).
      { name: "openarm_gripper_sim_passthrough", tag: "v1", link_id: "sim_passthrough" },
      // This gripper's measured opening on the generic joint_states contract
      // (positions[0]), re-emitted per side from the engine's broadcast so a
      // recorder or monitor binds this follower exactly like the real gripper.
      { name: "joint_states", tag: "v1", link_id: "states" },
      // The opening setpoint commanded to this gripper on the generic
      // joint_commands contract, so a recorder captures the action aligned with
      // joint_states. Per-gripper here (the backbone that computes it is one node
      // driving both grippers and cannot emit a per-gripper stream).
      { name: "joint_commands", tag: "v1", link_id: "commands" },
    ],
    depends_on: {
      pairings: [
        // The exclusive control conversation with ONE backbone instance:
        // streamed opening setpoints in, this gripper's sim aperture relayed
        // back, both scoped to the pair (no gripper_id demux). Optional and
        // mirrors the real gripper, so both follow the same contract.
        {
          name: "openarm_gripper_link",
          tag: "v1",
          role: "gripper",
          link_id: "backbone",
          optional: true,
        },
      ],
      contracts: [
        // Measured opening from the sim engine, demuxed by gripper_id and relayed
        // to the paired backbone and the per-side joint_states re-emit. This is
        // the one place gripper_id is still load-bearing: the engine is a single
        // producer for both grippers, which no generic per-side contract can
        // express. Bound to the sim instance at launch.
        {
          name: "openarm_gripper_states",
          tag: "v1",
          link_id: "engine_states",
        },
      ],
    },
  },
  interfaces: {
    topics: {
      emits: [
        { link_id: "sim_passthrough", name: "gripper_sim_passthrough" },
        { link_id: "states", name: "joint_states" },
        { link_id: "commands", name: "joint_commands" },
      ],
      consumes: [
        { name: "gripper_states", link_id: "engine_states" },
      ],
    },
  },
  execution: {
    language: "rust",
    container: {
      def_file: "apptainer.def",
    },
    parameters: {
      // The gripper_id at runtime (0 = left, 1 = right). Two instances are
      // expected; the bin's file-lock + gripper_id guard rejects collisions.
      gripper_id: "u8",
      // Control-loop rate (Hz) for the follow loop.
      control_rate_hz: "u32",
    },
  },
}
