Bootstrap: docker
From: tuatini/peppy-rust-cargo-base:latest

%labels
    Name openarm-gripper-isaac
    Version v1

%files
    . /opt/openarm_gripper_isaac

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive

    cd /opt/openarm_gripper_isaac
    cargo build --release

%runscript
    cd /opt/openarm_gripper_isaac
    exec ./target/release/openarm_gripper_isaac "$@"
