// Bridge plugin registry for the Isaac openarm scene. `prim` paths must match
// the USD stage — verify against openarm_bimanual.usd on first build.
{
  // Publishers emit raw peppylib JSON each tick.
  publishers: [
    // Whole-robot joint state. Arm Rust runtime subscribes and filters by
    // joint_names prefix (`openarm_<side>_joint`) to slice its 7-DOF set.
    { type: "joint_states", prim: "/openarm", topic: "joint_states", robot_name: "openarm" },

    // Per-side gripper finger joints (positions + measured forces).
    {
      type: "gripper_state", prim: "/openarm",
      topic: "gripper_state_left", robot_name: "openarm",
      params: { finger_joints: ["openarm_left_finger_joint1", "openarm_left_finger_joint2"] },
    },
    {
      type: "gripper_state", prim: "/openarm",
      topic: "gripper_state_right", robot_name: "openarm",
      params: { finger_joints: ["openarm_right_finger_joint1", "openarm_right_finger_joint2"] },
    },

    // Per-side end-effector pose (TCP body).
    { type: "ee_pose", prim: "/openarm/openarm_left_ee_tcp",  topic: "ee_pose_left",  robot_name: "openarm" },
    { type: "ee_pose", prim: "/openarm/openarm_right_ee_tcp", topic: "ee_pose_right", robot_name: "openarm" },

    // Whole-world TF tree.
    { type: "tf_tree", prim: "/openarm", topic: "tf_tree", robot_name: "openarm" },

    // Per-finger contacts. Disabled until 4 per-finger IsaacContactSensor entries
    // are wired against the correct USD finger prims (contract requires
    // contact_forces_left/right_finger1/2). Not needed for arm motion testing.
    // { type: "contact_forces", prim: "/openarm/openarm_left_left_finger",   topic: "contact_forces_left_finger1",  robot_name: "openarm" },
    // { type: "contact_forces", prim: "/openarm/openarm_left_right_finger",  topic: "contact_forces_left_finger2",  robot_name: "openarm" },
    // { type: "contact_forces", prim: "/openarm/openarm_right_left_finger",  topic: "contact_forces_right_finger1", robot_name: "openarm" },
    // { type: "contact_forces", prim: "/openarm/openarm_right_right_finger", topic: "contact_forces_right_finger2", robot_name: "openarm" },

    // IMU publishers: uncomment once IMU prims are placed in the USD.
    // { type: "imu", prim: "/World/openarm/left_imu",  topic: "imu_left",  robot_name: "openarm" },
    // { type: "imu", prim: "/World/openarm/right_imu", topic: "imu_right", robot_name: "openarm" },
  ],

  // Subscribers apply via ArticulationView. Topic: set_ctrl_<component>_<side>
  // with payload { actuator_values: { <joint_name>: <value>, ... } }.
  subscribers: [
    {
      type: "actuator_ctrl", prim: "/openarm",
      topic: "set_ctrl_gripper_left", source_node: "openarm01_gripper",
      params: { joint_names: ["openarm_left_finger_joint1", "openarm_left_finger_joint2"] },
    },
    {
      type: "actuator_ctrl", prim: "/openarm",
      topic: "set_ctrl_gripper_right", source_node: "openarm01_gripper",
      params: { joint_names: ["openarm_right_finger_joint1", "openarm_right_finger_joint2"] },
    },

    // Arm subscribers — IsaacActuatorCtrl uses joint_names to filter the
    // articulation's dof set. Names must match USD dof_names verbatim; check
    // for `unknown actuator … dropped` warnings if Articulation rejects entries.
    // kp/kd are the real driver's MIT gains and max_efforts the motor torque
    // caps (DM8009/4340/4310) — applied to the PhysX drives at setup so sim
    // servo dynamics match hardware.
    {
      type: "actuator_ctrl", prim: "/openarm",
      topic: "set_ctrl_arm_left", source_node: "openarm01_arm",
      params: {
        joint_names: [
          "openarm_left_joint1", "openarm_left_joint2", "openarm_left_joint3",
          "openarm_left_joint4", "openarm_left_joint5", "openarm_left_joint6",
          "openarm_left_joint7",
        ],
        kp: [70.0, 70.0, 70.0, 60.0, 10.0, 10.0, 10.0],
        kd: [2.75, 2.5, 2.0, 2.0, 0.7, 0.6, 0.5],
        max_efforts: [40.0, 40.0, 27.0, 27.0, 7.0, 7.0, 7.0],
      },
    },
    {
      type: "actuator_ctrl", prim: "/openarm",
      topic: "set_ctrl_arm_right", source_node: "openarm01_arm",
      params: {
        joint_names: [
          "openarm_right_joint1", "openarm_right_joint2", "openarm_right_joint3",
          "openarm_right_joint4", "openarm_right_joint5", "openarm_right_joint6",
          "openarm_right_joint7",
        ],
        kp: [70.0, 70.0, 70.0, 60.0, 10.0, 10.0, 10.0],
        kd: [2.75, 2.5, 2.0, 2.0, 0.7, 0.6, 0.5],
        max_efforts: [40.0, 40.0, 27.0, 27.0, 7.0, 7.0, 7.0],
      },
    },
  ],
}
