// openarm_backbone: the bimanual coordination node. Consumes the commander's
// arm_joint_commands and gripper_commands streams; exposes the joint /
// Cartesian / gripper move actions and executes them itself; emits
// collision_status; and drives each arm and each gripper over its own pairing
// (arm_link / gripper_link): governed setpoints stream down each pair and the
// measured state streams back on it. See src/main.rs for the architecture.
{
  peppy_schema: "node/v1",
  manifest: {
    name: "openarm_backbone",
    tag: "v1",
    depends_on: {
      contracts: [
        {
          name: "openarm_robot_initializer",
          tag: "v1",
          link_id: "robot_init"
        },
        // The commander's streamed setpoints, arm and gripper, bound to the one
        // commanding instance; sides told apart by arm_id / gripper_id. The
        // backbone governs both streams before anything reaches a follower.
        {
          name: "openarm_commands",
          tag: "v1",
          link_id: "commander"
        },
        // Runtime governor controls, bound to the commander; the backbone
        // holds its launch-time defaults until the first message.
        {
          name: "openarm_governor_control",
          tag: "v1",
          link_id: "collision_ctrl"
        }
      ],
      pairings: [
        // The exclusive command loop with each arm: the backbone plays the commander
        // role, streams the governed joint setpoint down each slot's
        // joint_setpoints, and reads that arm's measured state back on the slot's
        // joint_states (the governor's d_now and the trajectory anchor); the slot
        // scopes both directions, so no arm_id demux and no other producer can
        // drive an arm or pose as its state. Optional like the gripper slots
        // below, established at this instance's start (launcher `links:`).
        {
          name: "joint_link",
          tag: "v1",
          role: "commander",
          link_id: "left_arm_link",
          optional: true
        },
        {
          name: "joint_link",
          tag: "v1",
          role: "commander",
          link_id: "right_arm_link",
          optional: true
        },
        // The exclusive command loop with each gripper: the backbone plays the
        // commander role, streams the governed opening down each slot's
        // gripper_commands, and reads that gripper's measured aperture back on
        // the slot's gripper_states; the slot scopes both directions, so no
        // gripper_id demux and no other producer can pose as the fingers.
        // Optional: the backbone boots with either gripper unpaired (that side's
        // governed openings go nowhere and no aperture arrives, so streaming
        // stays gated) and each pair is established at this instance's start
        // (launcher `links:`).
        {
          name: "gripper_link",
          tag: "v1",
          role: "commander",
          link_id: "left_gripper_link",
          optional: true
        },
        {
          name: "gripper_link",
          tag: "v1",
          role: "commander",
          link_id: "right_gripper_link",
          optional: true
        }
      ]
    }
  },
  interfaces: {
    actions: {
      // The backbone's move actions, addressed by side id. The backbone runs each move
      // itself (trajectory + governor + governed stream); progress is observed
      // on the state streams. Discrete goals that return a result, distinct
      // from the arm_joint_commands / gripper_commands streams.
      exposes: [
        {
          name: "move_arm_joints",
          goal_service: {
            request_message_format: {
              // Which arm (0 = left, 1 = right).
              arm_id: "u8",
              // Target joint positions (rad), j1..j7.
              joint_positions: {
                $type: "array",
                $items: "f64",
                $length: 7
              },
              // Requested trajectory duration (s); floored at the per-joint
              // velocity-limit duration. 0 = fastest.
              duration_s: "f64"
            },
            response_message_format: {
              accepted: "bool"
            }
          },
          result_service: {
            response_message_format: {
              success: "bool",
              message: "string",
              // Measured joint positions (rad) when the action ended, j1..j7.
              final_joint_positions: {
                $type: "array",
                $items: "f64",
                $length: 7
              },
              // Wall-clock duration of the action (s).
              action_time: "f64"
            }
          }
        },
        {
          name: "move_arm",
          goal_service: {
            request_message_format: {
              // Which arm (0 = left, 1 = right).
              arm_id: "u8",
              // Target end-effector position in the world frame: x, y, z (m).
              position: {
                $type: "array",
                $items: "f64",
                $length: 3
              },
              // Target end-effector orientation, quaternion [x, y, z, w].
              orientation: {
                $type: "array",
                $items: "f64",
                $length: 4
              },
              // Requested trajectory duration (s); floored at the velocity-limit
              // duration. 0 = fastest.
              duration_s: "f64"
            },
            response_message_format: {
              accepted: "bool"
            }
          },
          result_service: {
            response_message_format: {
              success: "bool",
              message: "string",
              // Measured end-effector position when the action ended: x, y, z (m).
              final_position: {
                $type: "array",
                $items: "f64",
                $length: 3
              },
              // Measured end-effector orientation, quaternion [x, y, z, w].
              final_orientation: {
                $type: "array",
                $items: "f64",
                $length: 4
              },
              // Wall-clock duration of the action (s).
              action_time: "f64"
            }
          }
        },
        {
          name: "move_gripper",
          goal_service: {
            request_message_format: {
              // Which gripper (0 = left, 1 = right).
              gripper_id: "u8",
              // Target opening as a fraction of full jaw travel: 0 = closed,
              // 1 = fully open.
              opening: "f64"
            },
            response_message_format: {
              accepted: "bool"
            }
          },
          result_service: {
            response_message_format: {
              success: "bool",
              message: "string",
              // Measured opening fraction when the action ended.
              final_opening: "f64",
              // Wall-clock duration of the action (s).
              action_time: "f64"
            }
          }
        }
      ]
    },
    topics: {
      emits: [
        // The commander role's topic on each pairing slot: the governed
        // setpoint this node streams down to the paired arm or gripper. The
        // pairing document owns the shape and QoS, so these entries carry
        // only the reference. Emit coverage is exact: every topic the
        // commander role emits needs exactly one entry per slot.
        {
          name: "arm_setpoints",
          link_id: "left_arm_link"
        },
        {
          name: "arm_setpoints",
          link_id: "right_arm_link"
        },
        {
          name: "gripper_commands",
          link_id: "left_gripper_link"
        },
        {
          name: "gripper_commands",
          link_id: "right_gripper_link"
        },
        {
          // Nearest self-collision pair: the signed surface distance between the
          // two arms and the two links forming that pair.
          name: "collision_status",
          qos_profile: "sensor_data",
          message_format: {
            // Signed surface distance (m) of the nearest checked pair: positive is
            // clearance, negative is penetration depth.
            distance: "f64",
            // The two links forming that nearest pair.
            link_a: "string",
            link_b: "string",
            // Disposition of the commanded motion, mutually exclusive: throttled
            // means it is being scaled down to hold the band, stopped means it is
            // fully denied at the stop floor. Both false when motion is unrestricted.
            throttled: "bool",
            stopped: "bool"
          }
        },
      ],
      consumes: [
        // The counterpart-role topic of each pairing slot: the measured state
        // each paired arm and gripper streams back. One entry per slot, so
        // each stays addressable as peppygen.pairings.<slot>.<topic>.
        {
          name: "arm_states",
          link_id: "left_arm_link"
        },
        {
          name: "arm_states",
          link_id: "right_arm_link"
        },
        {
          name: "gripper_states",
          link_id: "left_gripper_link"
        },
        {
          name: "gripper_states",
          link_id: "right_gripper_link"
        },
        {
          name: "arm_joint_commands",
          link_id: "commander"
        },
        {
          name: "gripper_commands",
          link_id: "commander"
        },
        {
          name: "governor_control",
          link_id: "collision_ctrl"
        }
      ]
    },
    services: {
      consumes: [
        {
          link_id: "robot_init",
          name: "is_ready"
        }
      ]
    }
  },
  execution: {
    language: "rust",
    container: {
      def_file: "apptainer.def"
    },
    parameters: {
      // Which OpenArm hardware generation the arms are: "v1" or "v2". Selects the embedded
      // description (openarm_description) the srs_model arms and the bimanual collision
      // model are built from. Required, not defaulted: the wrong generation mis-models
      // the arms, so the launcher must be explicit. The torso proxy is shared across
      // generations (the bimanual stand is unchanged).
      hardware_version: "string",
      // Coordination loop rate (Hz): the rate governed setpoints are streamed at.
      control_rate_hz: "u32",
      // Self-collision governor band (m), signed surface distance between the two
      // arms. At/under d_stop motion toward contact is fully stopped; at/over
      // d_safe it is unthrottled; between, it ramps linearly. Separating motion
      // is never throttled (recovery from a tangle is always allowed). Require
      // 0 < d_stop < d_safe. The collision model was validated against
      // d_stop=0.005, d_safe=0.02: the rest-pose clearance (~24 mm of the nearest
      // checked pair) sits just above d_safe, so the home pose is unthrottled and
      // an approach throttles within ~2 cm.
      d_stop: "f64",
      d_safe: "f64",
      // Governor state at launch, before the first governor_control message.
      collision_governor_enabled: "bool",
      // Per-joint peak velocity (rad/s) sizing the quintic trajectories and the
      // stream chase. OpenArm V1.0 URDF joint velocity limits; the backbone is the sole
      // owner of motion sizing.
      max_joint_velocity_rad_s_1: { $type: "f64", $default: 16.754666 },
      max_joint_velocity_rad_s_2: { $type: "f64", $default: 16.754666 },
      max_joint_velocity_rad_s_3: { $type: "f64", $default: 5.445426 },
      max_joint_velocity_rad_s_4: { $type: "f64", $default: 5.445426 },
      max_joint_velocity_rad_s_5: { $type: "f64", $default: 20.943946 },
      max_joint_velocity_rad_s_6: { $type: "f64", $default: 20.943946 },
      max_joint_velocity_rad_s_7: { $type: "f64", $default: 20.943946 },
      // End-effector linear-speed cap (m/s) for the stream chase, used only until
      // the first governor_control message; after that the commander's streamed cap
      // (openarm_commander) governs. Require > 0. The sim launchers set a
      // permissive value; the real arm a conservative one.
      max_ee_velocity_m_s: "f64",
      // Cutoff (Hz) for the first-order low-pass on each published desired velocity.
      // Desired velocity is a per-tick position delta scaled by the control rate, so it
      // amplifies setpoint noise; filtering it keeps the arm's Kd term from buzzing on a
      // noisy stream without touching the desired position. At the 100 Hz control rate
      // (Nyquist 50 Hz) this must sit well below Nyquist to attenuate; ~15 Hz matches the
      // enactic reference's one-pole (its 90 rad/s constant is ~14.3 Hz) and adds about one
      // tick of group delay. A universal control constant (same across generations and
      // sim/real), so it keeps a node default like the gains.
      velocity_filter_cutoff_hz: { $type: "f64", $default: 15.0 },
    }
  }
}
