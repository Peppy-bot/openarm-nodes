// openarm_backbone: the bimanual coordination hub node. Consumes the operator
// arm_joint_commands and gripper_commands streams; exposes the joint /
// Cartesian / gripper move actions and executes them itself; conforms to
// collision_status; and drives each arm and each gripper over its own pairing
// (arm_link / gripper_link): governed setpoints stream down each pair and the
// measured state streams back on it. See src/main.rs for the architecture.
{
  peppy_schema: "node/v1",
  manifest: {
    name: "openarm_backbone",
    tag: "v1",
    depends_on: {
      contracts: [
        {
          name: "openarm_robot_initializer",
          tag: "v1",
          link_id: "robot_init"
        },
        // Operator joint setpoint stream: the launcher binds the slot to the
        // operator instance(s) and the hub tells sides apart by arm_id.
        {
          name: "openarm_arm_joint_commands",
          tag: "v1",
          link_id: "commander"
        },
        // Operator gripper opening stream, bound like the joint stream: the same
        // commander streams the desired opening per side (gripper_id); the hub
        // governs it (the finger opening barrier) and drives each gripper over
        // its pairing slot below, exactly as it does for the arm joint stream.
        {
          name: "openarm_gripper_commands",
          tag: "v1",
          link_id: "commander_gripper"
        },
        // Runtime on/off for the governor, bound to the operator panel. The hub
        // holds its launch-time default until the first message.
        {
          name: "openarm_governor_control",
          tag: "v1",
          link_id: "collision_ctrl"
        }
      ],
      pairings: [
        // The exclusive command loop with each arm: the hub plays the commander
        // role, streams the governed joint setpoint down each slot's
        // arm_setpoints, and reads that arm's measured state back on the slot's
        // arm_states (the governor's d_now and the trajectory anchor); the slot
        // scopes both directions, so no arm_id demux and no other producer can
        // drive an arm or pose as its state. Optional like the gripper slots
        // below, established at this instance's start (launcher `pairings:`).
        {
          name: "openarm_arm_link",
          tag: "v1",
          role: "commander",
          link_id: "left_arm_link",
          optional: true
        },
        {
          name: "openarm_arm_link",
          tag: "v1",
          role: "commander",
          link_id: "right_arm_link",
          optional: true
        },
        // The exclusive command loop with each gripper: the hub plays the
        // commander role, streams the governed opening down each slot's
        // gripper_commands, and reads that gripper's measured aperture back on
        // the slot's gripper_states; the slot scopes both directions, so no
        // gripper_id demux and no other producer can pose as the fingers.
        // Optional: the hub boots with either gripper unpaired (that side's
        // governed openings go nowhere and no aperture arrives, so streaming
        // stays gated) and each pair is established at this instance's start
        // (launcher `pairings:`).
        {
          name: "openarm_gripper_link",
          tag: "v1",
          role: "commander",
          link_id: "left_gripper_link",
          optional: true
        },
        {
          name: "openarm_gripper_link",
          tag: "v1",
          role: "commander",
          link_id: "right_gripper_link",
          optional: true
        }
      ]
    }
  },
  interfaces: {
    conforms_to: [
      {
        // Emits the live nearest-pair distance + links, for the operator readout.
        name: "openarm_collision_status",
        tag: "v1"
      }
    ],
    actions: {
      // The hub's move actions, addressed by side id. The hub runs each move
      // itself (trajectory + governor + governed stream); progress is observed
      // on the state streams. Discrete goals that return a result, distinct
      // from the arm_joint_commands / gripper_commands streams.
      exposes: [
        {
          name: "move_arm_joints",
          goal_service: {
            request_message_format: {
              // Which arm (0 = left, 1 = right).
              arm_id: "u8",
              // Target joint positions (rad), j1..j7.
              joint_positions: {
                $type: "array",
                $items: "f64",
                $length: 7
              },
              // Requested trajectory duration (s); floored at the per-joint
              // velocity-limit duration. 0 = fastest.
              duration_s: "f64"
            },
            response_message_format: {
              accepted: "bool"
            }
          },
          result_service: {
            response_message_format: {
              success: "bool",
              message: "string",
              // Measured joint positions (rad) when the action ended, j1..j7.
              final_joint_positions: {
                $type: "array",
                $items: "f64",
                $length: 7
              },
              // Wall-clock duration of the action (s).
              action_time: "f64"
            }
          }
        },
        {
          name: "move_arm",
          goal_service: {
            request_message_format: {
              // Which arm (0 = left, 1 = right).
              arm_id: "u8",
              // Target end-effector position in the world frame: x, y, z (m).
              position: {
                $type: "array",
                $items: "f64",
                $length: 3
              },
              // Target end-effector orientation, quaternion [x, y, z, w].
              orientation: {
                $type: "array",
                $items: "f64",
                $length: 4
              },
              // Requested trajectory duration (s); floored at the velocity-limit
              // duration. 0 = fastest.
              duration_s: "f64"
            },
            response_message_format: {
              accepted: "bool"
            }
          },
          result_service: {
            response_message_format: {
              success: "bool",
              message: "string",
              // Measured end-effector position when the action ended: x, y, z (m).
              final_position: {
                $type: "array",
                $items: "f64",
                $length: 3
              },
              // Measured end-effector orientation, quaternion [x, y, z, w].
              final_orientation: {
                $type: "array",
                $items: "f64",
                $length: 4
              },
              // Wall-clock duration of the action (s).
              action_time: "f64"
            }
          }
        },
        {
          name: "move_gripper",
          goal_service: {
            request_message_format: {
              // Which gripper (0 = left, 1 = right).
              gripper_id: "u8",
              // Target opening (m): 0.0 = closed, increasing toward fully open.
              position: "f64"
            },
            response_message_format: {
              accepted: "bool"
            }
          },
          result_service: {
            response_message_format: {
              success: "bool",
              message: "string",
              // Measured opening (m) when the action ended.
              final_joint_positions: {
                $type: "array",
                $items: "f64"
              },
              // Wall-clock duration of the action (s).
              action_time: "f64"
            }
          }
        }
      ]
    },
    topics: {
      consumes: [
        {
          name: "arm_joint_commands",
          link_id: "commander"
        },
        {
          name: "gripper_commands",
          link_id: "commander_gripper"
        },
        {
          name: "governor_control",
          link_id: "collision_ctrl"
        }
      ]
    },
    services: {
      consumes: [
        {
          link_id: "robot_init",
          name: "is_ready"
        }
      ]
    }
  },
  execution: {
    language: "rust",
    container: {
      def_file: "apptainer.def"
    },
    parameters: {
      // Which OpenArm hardware generation the arms are: "v1" or "v2". Selects the embedded
      // description (openarm_description) the srs_model arms and the bimanual collision
      // model are built from. Required, not defaulted: the wrong generation mis-models
      // the arms, so the launcher must be explicit. The torso proxy is shared across
      // generations (the bimanual stand is unchanged).
      hardware_version: "string",
      // Per-side base links selecting the two SRS chains in the embedded description, used
      // for both srs_model arms and the bimanual collision model. v1 uses
      // "openarm_{left,right}_link0"; v2 renamed them to "openarm_{left,right}_base_link".
      // The governor's torso proxy (see the `torso` module) is hand-fitted to the shared
      // stand mesh; the collision model's build() aborts without the expected torso.
      left_base: { $type: "string", $default: "openarm_left_link0" },
      right_base: { $type: "string", $default: "openarm_right_link0" },
      // Coordination loop rate (Hz): the rate governed setpoints are streamed at.
      control_rate_hz: "u32",
      // Self-collision governor band (m), signed surface distance between the two
      // arms. At/under d_stop motion toward contact is fully stopped; at/over
      // d_safe it is unthrottled; between, it ramps linearly. Separating motion
      // is never throttled (recovery from a tangle is always allowed). Require
      // 0 < d_stop < d_safe. The collision model was validated against
      // d_stop=0.005, d_safe=0.02: the rest-pose clearance (~24 mm of the nearest
      // checked pair) sits just above d_safe, so the home pose is unthrottled and
      // an approach throttles within ~2 cm.
      d_stop: "f64",
      d_safe: "f64",
      // Governor state at launch, before the first governor_control message.
      collision_governor_enabled: "bool",
      // Per-joint peak velocity (rad/s) sizing the quintic trajectories and the
      // stream chase. OpenArm V1.0 URDF joint velocity limits; the hub is the sole
      // owner of motion sizing.
      max_joint_velocity_rad_s_1: { $type: "f64", $default: 16.754666 },
      max_joint_velocity_rad_s_2: { $type: "f64", $default: 16.754666 },
      max_joint_velocity_rad_s_3: { $type: "f64", $default: 5.445426 },
      max_joint_velocity_rad_s_4: { $type: "f64", $default: 5.445426 },
      max_joint_velocity_rad_s_5: { $type: "f64", $default: 20.943946 },
      max_joint_velocity_rad_s_6: { $type: "f64", $default: 20.943946 },
      max_joint_velocity_rad_s_7: { $type: "f64", $default: 20.943946 },
      // End-effector linear-speed cap (m/s) for the stream chase, used only until
      // the first governor_control message; after that the operator's streamed cap
      // (openarm_joint_commander) governs. Require > 0. The sim launchers set a
      // permissive value; the real arm a conservative one.
      max_ee_velocity_m_s: "f64",
      // How long (s) the hub keeps following an operator stream after its last
      // message before releasing the lock and holding.
      stream_timeout_s: "f64",
      // Completion tolerance (m) for hub-executed move_gripper goals: the goal
      // completes when the measured opening is within this of the target.
      gripper_position_tolerance: { $type: "f64", $default: 0.001 },
      // Deadline (s) for hub-executed move_gripper goals; a goal the governed
      // opening cannot reach (a collision clamp) fails here.
      gripper_motion_timeout_s: { $type: "f64", $default: 10.0 },
    }
  }
}
