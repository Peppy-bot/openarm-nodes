// openarm_commander: the browser-based commander. Serves a
// control panel (HTTP + WebSocket on PEPPY_JC_PORT, default 8765) that streams
// arm and gripper setpoints to the backbone over the joint_link / gripper_link
// pairings (the backbone governs and re-streams them), reads live state by
// observing the backbone's downstream pairings, jogs the arm in joint or
// Cartesian (world-frame IK) space, and fires move_arm_joints / move_arm /
// move_gripper goals at openarm_backbone.
{
  peppy_schema: "node/v1",
  manifest: {
    name: "openarm_commander",
    tag: "v1",
    implements: [
      // Runtime on/off for the backbone's self-collision governor, driven by the UI.
      { name: "openarm_governor_control", tag: "v1", link_id: "governor" },
    ],
    depends_on: {
      nodes: [
        // The backbone: the move actions the panel fires (move_arm_joints is the
        // "Send" button) and the collision_status feed behind the proximity
        // readout. Bound to the backbone instance in the launcher.
        {
          name: "openarm_backbone",
          tag: "v1",
          link_id: "backbone"
        }
      ],
      pairings: [
        // The exclusive command loop with the backbone, one slot per driven
        // limb: this panel plays the commander role and streams the operator's
        // raw setpoints; the backbone governs them before anything reaches a
        // follower. Optional: a monitor-only deployment (the leader owns the
        // command loop) boots with these unbound and the panel is read-only.
        { name: "joint_link", tag: "v1", role: "commander", link_id: "left_arm", optional: true },
        { name: "joint_link", tag: "v1", role: "commander", link_id: "right_arm", optional: true },
        { name: "gripper_link", tag: "v1", role: "commander", link_id: "left_gripper", optional: true },
        { name: "gripper_link", tag: "v1", role: "commander", link_id: "right_gripper", optional: true },
        // Live readouts: observe each backbone<->follower pairing's state
        // back-channel (positions for the sliders, gripper opening and effort
        // ceiling for the aperture and effort controls). Observing works in
        // every deployment, including ones where another node commands.
        { name: "joint_link", tag: "v1", observes_role: "follower", link_id: "observed_left_arm" },
        { name: "joint_link", tag: "v1", observes_role: "follower", link_id: "observed_right_arm" },
        { name: "gripper_link", tag: "v1", observes_role: "follower", link_id: "observed_left_gripper" },
        { name: "gripper_link", tag: "v1", observes_role: "follower", link_id: "observed_right_gripper" },
      ]
    }
  },
  interfaces: {
    // Streams operator setpoints to the backbone on the per-limb pairing slots.
    // Producing these is what lets the panel drive an enabled arm/gripper
    // continuously instead of one move at a time; the backbone governs each and
    // re-streams the governed value, so a follower clamps and rate-limits on
    // its side.
    actions: {
      // Goals fired by the operator land on the backbone, which runs the move itself
      // for the arm whose id matches arm_id.
      consumes: [
        {
          link_id: "backbone",
          name: "move_arm_joints"
        },
        // Cartesian point-to-point: Execute-pose in the panel's Actions mode fires
        // the backbone's planned straight-line move rather than jogging there.
        {
          link_id: "backbone",
          name: "move_arm"
        },
        // Gripper open/close as a discrete governed action (Actions mode), rather
        // than the streamed opening used in Streaming mode.
        {
          link_id: "backbone",
          name: "move_gripper"
        }
      ]
    },
    topics: {
      // The UI's producer streams. The governor control is re-published
      // periodically (lossy QoS) so a dropped toggle cannot strand the backbone.
      emits: [
        { link_id: "left_arm", name: "joint_setpoints" },
        { link_id: "right_arm", name: "joint_setpoints" },
        { link_id: "left_gripper", name: "gripper_setpoints" },
        { link_id: "right_gripper", name: "gripper_setpoints" },
        { link_id: "governor", name: "governor_control" },
      ],
      consumes: [
        {
          name: "collision_status",
          link_id: "backbone"
        },
        // The observed pairings' state back-channels.
        { name: "joint_states", link_id: "observed_left_arm" },
        { name: "joint_states", link_id: "observed_right_arm" },
        { name: "gripper_states", link_id: "observed_left_gripper" },
        { name: "gripper_states", link_id: "observed_right_gripper" },
      ]
    }
  },
  execution: {
    language: "rust",
    container: {
      def_file: "apptainer.def"
    },
    parameters: {
      // Rate (Hz) at which enabled commander arm targets are re-published on
      // arm_joint_commands, which the backbone consumes.
      command_rate_hz: "u32",
      // Robot generation ("v1" or "v2"): picks the panel's arm joint ranges
      // (URDF limits), so the launcher must be explicit. The gripper axis is
      // the unitless opening fraction on every generation.
      hardware_version: "string",
      // Operator's launch end-effector speed cap (m/s), streamed live to the backbone on
      // governor_control and retunable from the UI. Require > 0. The sim launchers
      // set a permissive value; the real arm a conservative one.
      max_ee_velocity_m_s: "f64",
      // Joint-slider jog feel: the acceleration (rad/s^2) the streamed target ramps toward
      // the slider under. The whole jog is acceleration-limited (ramp up, brake to rest),
      // so this alone sets the smoothness. A node parameter so it can be tuned per
      // deployment without a rebuild; the backbone still governs the final motion. Lower is
      // gentler.
      joint_jog_acceleration_rad_s2: { $type: "f64", $default: 10.0 },
      // Launch state for the rest of the governor controls the commander streams live
      // on governor_control, set per deployment in step with openarm_backbone. The
      // band requires 0 < d_stop < d_safe.
      collision_governor_enabled: "bool",
      d_stop: "f64",
      d_safe: "f64"
    }
  }
}
