// openarm_commander: the browser-based commander. Serves a
// control panel (HTTP + WebSocket on PEPPY_JC_PORT, default 8765) that streams
// commander arm and gripper setpoints to the backbone (which governs and re-streams
// them), jogs the arm in joint or Cartesian (world-frame IK) space, and fires
// move_arm_joints / move_arm / move_gripper goals at openarm_backbone.
{
  peppy_schema: "node/v1",
  manifest: {
    name: "openarm_commander",
    tag: "v1",
    implements: [
      { name: "openarm_commands", tag: "v1", link_id: "commands" },
      // Runtime on/off for the backbone's self-collision governor, driven by the UI.
      { name: "openarm_governor_control", tag: "v1", link_id: "governor" },
    ],
    depends_on: {
      nodes: [
        // The backbone: the move actions the panel fires (move_arm_joints is the
        // "Send" button) and the collision_status feed behind the proximity
        // readout. Bound to the backbone instance in the launcher.
        {
          name: "openarm_backbone",
          tag: "v1",
          link_id: "backbone"
        }
      ],
      contracts: [
        // Measured joint state of both arms, for live UI progress. The launcher
        // binds one slot per state producer and the panel tells arms apart by
        // `arm_id`; a bound producer that isn't streaming yet just means no
        // readout. This replaces reading move progress off the action feedback.
        { name: "openarm_arm_states", tag: "v1", link_id: "left_arm_states" },
        { name: "openarm_arm_states", tag: "v1", link_id: "right_arm_states" },
        // Measured gripper opening of both grippers, for the live aperture
        // readout. Bound like arm_states and told apart by gripper_id; the
        // grippers stream this to the backbone and the panel alike.
        { name: "openarm_gripper_states", tag: "v1", link_id: "left_gripper_states" },
        { name: "openarm_gripper_states", tag: "v1", link_id: "right_gripper_states" },
      ]
    }
  },
  interfaces: {
    // Streams commander setpoints to the backbone: arm targets on arm_joint_commands and
    // gripper openings on gripper_commands, both told apart by id. Producing these
    // is what lets the panel drive an enabled arm/gripper continuously instead of
    // one move at a time; the backbone governs each and re-streams the governed value,
    // so a follower clamps and rate-limits on its side.
    actions: {
      // Goals fired by the operator land on the backbone, which runs the move itself
      // for the arm whose id matches arm_id.
      consumes: [
        {
          link_id: "backbone",
          name: "move_arm_joints"
        },
        // Cartesian point-to-point: Execute-pose in the panel's Actions mode fires
        // the backbone's planned straight-line move rather than jogging there.
        {
          link_id: "backbone",
          name: "move_arm"
        },
        // Gripper open/close as a discrete governed action (Actions mode), rather
        // than the streamed opening used in Streaming mode.
        {
          link_id: "backbone",
          name: "move_gripper"
        }
      ]
    },
    topics: {
      // The UI's producer streams. The governor control is re-published
      // periodically (lossy QoS) so a dropped toggle cannot strand the backbone.
      emits: [
        { link_id: "commands", name: "arm_joint_commands" },
        { link_id: "commands", name: "gripper_commands" },
        { link_id: "governor", name: "governor_control" },
      ],
      consumes: [
        { name: "arm_states", link_id: "left_arm_states" },
        { name: "arm_states", link_id: "right_arm_states" },
        {
          name: "collision_status",
          link_id: "backbone"
        },
        { name: "gripper_states", link_id: "left_gripper_states" },
        { name: "gripper_states", link_id: "right_gripper_states" },
      ]
    }
  },
  execution: {
    language: "rust",
    container: {
      def_file: "apptainer.def"
    },
    parameters: {
      // Rate (Hz) at which enabled commander arm targets are re-published on
      // arm_joint_commands, which the backbone consumes.
      command_rate_hz: "u32",
      // Robot generation ("v1" or "v2"): picks the panel's arm joint ranges
      // (URDF limits), so the launcher must be explicit. The gripper axis is
      // the unitless opening fraction on every generation.
      hardware_version: "string",
      // Operator's launch end-effector speed cap (m/s), streamed live to the backbone on
      // governor_control and retunable from the UI. Require > 0. The sim launchers
      // set a permissive value; the real arm a conservative one.
      max_ee_velocity_m_s: "f64",
      // Launch state for the rest of the governor controls the commander streams live
      // on governor_control, set per deployment in step with openarm_backbone. The
      // band requires 0 < d_stop < d_safe.
      collision_governor_enabled: "bool",
      d_stop: "f64",
      d_safe: "f64"
    }
  }
}
