Bootstrap: docker
From: tuatini/peppy-rust-cargo-base:latest

%labels
    Name openarm-gripper-mujoco
    Version v1

%files
    . /opt/openarm_gripper_mujoco

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive

    cd /opt/openarm_gripper_mujoco
    cargo build --release

%runscript
    cd /opt/openarm_gripper_mujoco
    exec ./target/release/openarm_gripper_mujoco "$@"
