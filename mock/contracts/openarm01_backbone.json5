// ORCHESTRATOR node — sim/real AGNOSTIC, NO variants
// Responsibilities:
//   1. Poll robot_initializer.is_ready at startup and wait
//   2. Discover arm/gripper IDs via get_arm_id / get_gripper_id
//   3. Receive move_arm action from joint_commander
//   4. Fire solve_ik ACTION on IK → get joint_positions
//   5. Fire move_joints ACTION on collisions_detection → monitor must_stop throughout motion
//   6. Fire move_arm ACTION to arm instance if CD clears it
//
// Backbone does NOT re-emit arm topics.
// joint_commander consumes arm/joint_states directly as external topic
//
// This node NEVER touches sim code. It doesn't know if isaac, mujoco, or real is running.
{
  peppy_schema: "node_v1",
  manifest: {
    name: "openarm01_backbone",
    tag: "0.1.0",
    // NO variants — sim/real agnostic
    depends_on: {
      nodes: [
        { name: "openarm01_robot_initializer", tag: "0.1.0", local_id: "robot_initializer"    },
        { name: "inverse_kinematics",          tag: "0.1.0", local_id: "inverse_kinematics"   },
        { name: "collisions_detection",        tag: "0.1.0", local_id: "collisions_detection" },
        { name: "openarm01_arm",               tag: "0.1.0", local_id: "openarm01_arm"         },
        { name: "openarm01_gripper",           tag: "0.1.0", local_id: "openarm01_gripper"     },
      ],
    },
  },
  interfaces: {
    services: {
      consumes: [
        // --- Startup handshake ---
        { local_node_id: "robot_initializer", name: "is_ready"       },
        // --- Discover arm/gripper side at boot ---
        { local_node_id: "openarm01_arm",     name: "get_arm_id"     },
        { local_node_id: "openarm01_gripper", name: "get_gripper_id" },
      ],
    },
    actions: {
      exposes: [
        // Exposed upward to joint_commander — same signature as arm's move_arm
        {
          name: "move_arm",
          goal_service: {
            request_message_format: {
              arm_id:              "u8",
              feedback_frequency:  "u32",
              desired_position:    { $type: "array", $items: "f64", $length: 3 }, // cartesian XYZ
              desired_orientation: { $type: "array", $items: "f64", $length: 4 }, // quaternion XYZW
            },
            response_message_format: { accepted: "bool" },
          },
          feedback_topic: {
            qos_profile: "sensor_data",
            message_format: {
              joint_positions: { $type: "array", $items: "f64" },
              action_time:     "f64",
            },
          },
          result_service: {
            response_message_format: {
              success:               "bool",
              message:               "string",
              final_joint_positions: { $type: "array", $items: "f64" },
              action_time:           "f64",
            },
          },
        },
        // Exposed upward to joint_commander — same signature as gripper's move_gripper
        {
          name: "move_gripper",
          goal_service: {
            request_message_format: {
              gripper_id:         "u8",
              feedback_frequency: "u32",
              desired_position:   "f64", // meters — 0.0 closed, 0.044 fully open (V10)
            },
            response_message_format: { accepted: "bool" },
          },
          feedback_topic: {
            qos_profile: "sensor_data",
            message_format: {
              joint_positions: { $type: "array", $items: "f64" },
              action_time:     "f64",
            },
          },
          result_service: {
            response_message_format: {
              success:               "bool",
              message:               "string",
              final_joint_positions: { $type: "array", $items: "f64" },
              action_time:           "f64",
            },
          },
        },
      ],
      consumes: [
        // --- Safety pipeline (both are ACTIONS, not services) ---
        { local_node_id: "inverse_kinematics",  name: "solve_ik"     }, // fire → get joint_positions
        { local_node_id: "collisions_detection", name: "move_joints" }, // fire → stream must_stop feedback
        // --- Execute on arm/gripper ---
        { local_node_id: "openarm01_arm",       name: "move_arm"     },
        { local_node_id: "openarm01_gripper",   name: "move_gripper" },
      ],
    },
    topics: {
      consumes: [
        // Backbone tracks arm state internally to seed IK (current_joints)
        { local_node_id: "openarm01_arm", name: "joint_states" },
      ],
    },
  },
  execution: {
    language: "rust",
    build_cmd: ["cargo", "build", "--release"],
    run_cmd:   ["./target/release/openarm01_backbone"],
  },
}
