// ROOT node — owns sim/real abstraction for the arm
// 2 instances at runtime: left_arm (arm_id=0), right_arm (arm_id=1)
// arm_id in execution.parameters tells backbone which side this is
// Sim process is started by openarm01_robot_initializer, not here
//
// Emits arm-level telemetry only (4 topics): joint_states, imu_left, imu_right, tf_tree
{
  peppy_schema: "node_v1",
  manifest: {
    name: "openarm01_arm",
    tag: "0.1.0",
    // NO depends_on — pure ROOT
    variants: [
      { name: "default", source: { local: "./variants/real"   } }, // real hardware driver
      { name: "isaac",   source: { local: "./variants/isaac"  } }, // Isaac Sim extension
      { name: "mujoco",  source: { local: "./variants/mujoco" } }, // MuJoCo extension
    ],
  },
  interfaces: {
    services: {
      exposes: [
        {
          name: "get_arm_id",
          // backbone calls this at startup to discover left vs right
          response_message_format: {
            arm_id: "u8",
          },
        },
      ],
    },
    actions: {
      exposes: [
        {
          name: "move_arm",
          goal_service: {
            request_message_format: {
              feedback_frequency: "u32",
              joint_positions:    { $type: "array", $items: "f64" }, // IK-solved joints from backbone
            },
            response_message_format: {
              accepted: "bool",
            },
          },
          feedback_topic: {
            qos_profile: "sensor_data",
            message_format: {
              joint_positions: { $type: "array", $items: "f64" },
              action_time:     "f64",
            },
          },
          result_service: {
            response_message_format: {
              success:               "bool",
              message:               "string",
              final_joint_positions: { $type: "array", $items: "f64" },
              action_time:           "f64",
            },
          },
        },
      ],
    },
    topics: {
      emits: [
        // --- Joint state ---
        {
          name: "joint_states",
          qos_profile: "sensor_data",
          message_format: {
            robot:      "string",
            step:       "u64",
            positions:  { $type: "array", $items: "f64" },
            velocities: { $type: "array", $items: "f64" },
            stamp:      "f64",
          },
        },
        // --- IMU (one per side) ---
        {
          name: "imu_left",
          qos_profile: "sensor_data",
          message_format: {
            robot:               "string",
            step:                "u64",
            orientation:         { $type: "array", $items: "f64", $length: 4 },
            angular_velocity:    { $type: "array", $items: "f64", $length: 3 },
            linear_acceleration: { $type: "array", $items: "f64", $length: 3 },
            stamp:               "f64",
          },
        },
        {
          name: "imu_right",
          qos_profile: "sensor_data",
          message_format: {
            robot:               "string",
            step:                "u64",
            orientation:         { $type: "array", $items: "f64", $length: 4 },
            angular_velocity:    { $type: "array", $items: "f64", $length: 3 },
            linear_acceleration: { $type: "array", $items: "f64", $length: 3 },
            stamp:               "f64",
          },
        },
        // --- TF tree ---
        {
          name: "tf_tree",
          qos_profile: "sensor_data",
          message_format: {
            robot: "string",
            step:  "u64",
            frames: {
              $type: "array",
              $items: {
                $type:       "object",
                name:        "string",
                parent:      "string",
                position:    { $type: "array", $items: "f64", $length: 3 },
                orientation: { $type: "array", $items: "f64", $length: 4 },
              },
            },
            stamp: "f64",
          },
        },
      ],
    },
  },
  execution: {
    language: "rust",
    parameters: {
      arm_id: "u8", // 0 = left, 1 = right — set per instance in launcher
    },
  },
}
