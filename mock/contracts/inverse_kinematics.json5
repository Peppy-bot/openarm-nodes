// ROOT node — stateless IK solver, ×2 instances one per arm
// backbone discovers instances at runtime via peppylib::stack_list and fires in parallel
// runs on every step of arm movement, not a one-shot pre-check
// IK streams convergence feedback and returns joint_positions on result
{
  peppy_schema: "node_v1",
  manifest: {
    name: "inverse_kinematics",
    tag: "0.1.0",
    // NO depends_on — pure ROOT
  },
  interfaces: {
    actions: {
      exposes: [
        {
          name: "solve_ik",
          goal_service: {
            request_message_format: {
              arm_id:             "u8",
              target_position:    { $type: "array", $items: "f64", $length: 3 }, // cartesian XYZ
              target_orientation: { $type: "array", $items: "f64", $length: 4 }, // quaternion XYZW
              current_joints:     { $type: "array", $items: "f64" },             // seed for solver
            },
            response_message_format: {
              accepted: "bool",
            },
          },
          feedback_topic: {
            qos_profile: "sensor_data",
            message_format: {
              joint_positions: { $type: "array", $items: "f64" }, // current best solution
              iteration:       "u32",
            },
          },
          result_service: {
            response_message_format: {
              success:         "bool",
              joint_positions: { $type: "array", $items: "f64" },
              error_msg: {
                $type:     "string",
                $optional: true,
              },
            },
          },
        },
      ],
    },
  },
  execution: {
    language: "python",
    build_cmd: ["uv", "sync"],
    run_cmd:   [".venv/bin/python", "-m", "inverse_kinematics"],
  },
}
