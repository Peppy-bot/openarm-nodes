// MUJOCO SIM launcher
// openarm01_robot_initializer mujoco variant = starts MuJoCo process, polls until scene loaded
// All component nodes use mujoco variants
// peppy_schema: "launcher_v1" — requires peppy v0.9.0+
{
  peppy_schema: "launcher_v1",
  deployments: [
    // ── Safety / IK (always same, no variants) ─────────────────────────────
    {
      source: { name: "collisions_detection:0.1.0" },
      instances: [
        { instance_id: "collisions", arguments: {} }
      ],
    },
    {
      source: { name: "inverse_kinematics:0.1.0" },
      instances: [
        { instance_id: "ik", arguments: {} }
      ],
    },

    // ── Robot initializer — mujoco variant starts MuJoCo process ───────────
    {
      source: {
        name: "openarm01_robot_initializer:0.1.0",
        variant: { name: "mujoco" }  // starts MuJoCo, polls until scene is loaded
      },
      instances: [
        { instance_id: "robot_init", arguments: {} }
      ],
    },

    // ── Depth cameras — mujoco sim variant ─────────────────────────────────
    {
      source: {
        name: "depth_camera:0.1.0",
        variant: { name: "mujoco" }
      },
      instances: [
        { instance_id: "torso_front_camera", arguments: { device_path: "" } },
        { instance_id: "left_arm_camera",    arguments: { device_path: "" } },
        { instance_id: "right_arm_camera",   arguments: { device_path: "" } },
      ],
    },

    // ── Arms — mujoco variant ──────────────────────────────────────────────
    {
      source: {
        name: "openarm01_arm:0.1.0",
        variant: { name: "mujoco" }
      },
      instances: [
        { instance_id: "left_arm",  arguments: { arm_id: 0 } },
        { instance_id: "right_arm", arguments: { arm_id: 1 } },
      ],
    },

    // ── Grippers — mujoco variant ──────────────────────────────────────────
    {
      source: {
        name: "openarm01_gripper:0.1.0",
        variant: { name: "mujoco" }
      },
      instances: [
        { instance_id: "left_gripper",  arguments: { gripper_id: 0 } },
        { instance_id: "right_gripper", arguments: { gripper_id: 1 } },
      ],
    },

    // ── Backbone — no variants, always same ────────────────────────────────
    {
      source: { name: "openarm01_backbone:0.1.0" },
      instances: [
        { instance_id: "backbone", arguments: {} }
      ],
    },

    // ── Joint commander ────────────────────────────────────────────────────
    {
      source: { name: "openarm01_joint_commander:0.1.0" },
      instances: [
        { instance_id: "commander", arguments: {} }
      ],
    },
  ],
}
