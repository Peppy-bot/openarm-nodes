// TOP-LEVEL node — sends cartesian move_arm goals to backbone
// keyboard variant: TUI input, shows live joint_states
// pose_estimation variant: reads depth_camera video_stream, computes pose → fires move_arm
//
// joint_commander consumes arm/joint_states as EXTERNAL topic (no depends_on on arm)
// backbone does not re-emit it — joint_commander subscribes to the source directly
{
  peppy_schema: "node_v1",
  manifest: {
    name: "openarm01_joint_commander",
    tag: "0.1.0",
    depends_on: {
      nodes: [
        { name: "openarm01_backbone", tag: "0.1.0", local_id: "openarm01_backbone" },
        { name: "depth_camera",       tag: "0.1.0", local_id: "depth_camera"       },
      ],
    },
    variants: [
      { name: "default",         source: { local: "./variants/keyboard"        } }, // TUI keyboard
      { name: "pose_estimation", source: { local: "./variants/pose_estimation" } }, // vision-based
    ],
  },
  interfaces: {
    actions: {
      consumes: [
        { local_node_id: "openarm01_backbone", name: "move_arm"     },
        { local_node_id: "openarm01_backbone", name: "move_gripper" },
      ],
    },
    topics: {
      consumes: [
        // --- External topic: arm/joint_states ---
        // No local_node_id — consumed directly from arm without depends_on on arm.
        // keyboard variant: displays live joint positions in TUI
        // pose_estimation variant: uses current pose as IK seed reference
        {
          name: "joint_states",
          qos_profile: "sensor_data",
          message_format: {
            robot:      "string",
            step:       "u64",
            positions:  { $type: "array", $items: "f64" },
            velocities: { $type: "array", $items: "f64" },
            stamp:      "f64",
          },
        },
        // --- From depth_camera (linked via depends_on) ---
        // pose_estimation variant only — keyboard variant ignores this
        { local_node_id: "depth_camera", name: "video_stream" },
      ],
      emits: [
        // pose_estimation variant only
        {
          name: "teleop/marker_pose",
          qos_profile: "sensor_data",
          message_format: {
            position:    { $type: "array", $items: "f64", $length: 3 },
            orientation: { $type: "array", $items: "f64", $length: 4 },
            timestamp:   "f64",
            confidence:  "f64",
          },
        },
        {
          name: "teleop/hand_pose",
          qos_profile: "sensor_data",
          message_format: {
            open_fraction: "f64",
            timestamp:     "f64",
            confidence:    "f64",
          },
        },
      ],
    },
  },
  execution: {
    language: "rust",
    build_cmd: ["cargo", "build", "--release"],
    run_cmd:   ["./target/release/openarm01_joint_commander"],
  },
}
