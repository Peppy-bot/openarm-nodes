// ROOT node — stateless collision checker (Coal library)
// backbone fires move_joints action, CD monitors throughout and streams must_stop + stop_type feedback
// must_stop goes to backbone — backbone cancels arm/gripper action, CD never talks to arm/gripper directly
// continuously consumes left/right arm joint_states + depth_camera feeds for real-time monitoring
{
  peppy_schema: "node_v1",
  manifest: {
    name: "collisions_detection",
    tag: "0.1.0",
    // NO depends_on — pure ROOT
  },
  interfaces: {
    actions: {
      exposes: [
        {
          name: "move_joints",
          goal_service: {
            request_message_format: {
              arm_id:             "u8",
              feedback_frequency: "u32",
              joint_positions:    { $type: "array", $items: "f64" }, // target joint positions to validate
            },
            response_message_format: {
              accepted: "bool",
            },
          },
          feedback_topic: {
            qos_profile: "sensor_data",
            message_format: {
              joint_positions: { $type: "array", $items: "f64" },
              action_time:     "f64",
              must_stop:       "bool",   // true → backbone cancels arm/gripper action immediately
              stop_type:       "string", // "abrupt" | "controlled" | "trajectory"
            },
          },
          result_service: {
            response_message_format: {
              success:               "bool",
              message:               "string",
              final_joint_positions: { $type: "array", $items: "f64" },
              action_time:           "f64",
            },
          },
        },
      ],
    },
    topics: {
      consumes: [
        // real-time self collision + inter-arm collision monitoring
        { name: "joint_states", local_node_id: "left_arm"  },
        { name: "joint_states", local_node_id: "right_arm" },
        // real-time environment collision monitoring
        { name: "video_stream", local_node_id: "torso_front_camera" },
        { name: "video_stream", local_node_id: "left_arm_camera"    },
        { name: "video_stream", local_node_id: "right_arm_camera"   },
      ],
    },
  },
  execution: {
    language: "python",
    build_cmd: ["uv", "sync"],
    run_cmd:   [".venv/bin/python", "-m", "collisions_detection"],
  },
}
