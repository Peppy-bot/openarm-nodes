// ROOT node — stateless collision checker (Coal library)
// backbone fires move_joints action at start of each arm movement
// CD monitors joint trajectory throughout and streams must_stop + stop_type feedback
// covers full motion, not a point-in-time snapshot
// CONFIRMED (Tuatini 2026-05-11): must_stop goes to backbone, backbone cancels arm/gripper — CD never talks to arm/gripper directly
{
  peppy_schema: "node_v1",
  manifest: {
    name: "collisions_detection",
    tag: "0.1.0",
    // NO depends_on — pure ROOT
  },
  interfaces: {
    actions: {
      exposes: [
        {
          name: "move_joints",
          goal_service: {
            request_message_format: {
              arm_id:             "u8",
              feedback_frequency: "u32",
              joint_positions:    { $type: "array", $items: "f64" }, // target joint positions to validate
            },
            response_message_format: {
              accepted: "bool",
            },
          },
          feedback_topic: {
            qos_profile: "sensor_data",
            message_format: {
              joint_positions: { $type: "array", $items: "f64" },
              action_time:     "f64",
              must_stop:       "bool",   // true → backbone cancels arm/gripper action immediately
              stop_type:       "string", // "abrupt" | "controlled" | "trajectory"
            },
          },
          result_service: {
            response_message_format: {
              success:               "bool",
              message:               "string",
              final_joint_positions: { $type: "array", $items: "f64" },
              action_time:           "f64",
            },
          },
        },
      ],
    },
  },
  execution: {
    language: "python",
    build_cmd: ["uv", "sync"],
    run_cmd:   [".venv/bin/python", "-m", "collisions_detection"],
  },
}
