// ROOT node — stateless collision checker (Coal library)
// backbone calls check_collisions before issuing joint commands to arm
{
  schema_version: 1,
  manifest: {
    name: "collisions_detection",
    tag: "0.1.0",
    // NO depends_on — pure ROOT
  },
  interfaces: {
    services: {
      exposes: [
        {
          name: "check_collisions",
          request_message_format: {
            arm_id:          "u8",
            joint_positions: { $type: "array", $items: "f64" }, // proposed joint positions to check
          },
          response_message_format: {
            safe:      "bool",
            error_msg: {
              $type:     "string",
              $optional: true,
            },
          },
        },
      ],
    },
  },
  execution: {
    language: "python",
    build_cmd: ["uv", "sync"],
    run_cmd:   [".venv/bin/python", "-m", "collisions_detection"],
  },
}
