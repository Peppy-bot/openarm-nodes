Bootstrap: docker
From: tuatini/peppy-rust-cargo-base:latest

%labels
    Name openarm01-gripper-mujoco
    Version 0.1.0

%files
    . /opt/openarm01_gripper_mujoco

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive

    cd /opt/openarm01_gripper_mujoco
    cargo build --release

%runscript
    cd /opt/openarm01_gripper_mujoco
    exec ./target/release/openarm01_gripper_mujoco "$@"
