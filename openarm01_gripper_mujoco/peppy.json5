// MuJoCo sim implementation of openarm01_gripper. Rust node talking to a
// running MuJoCo sim via raw peppylib JSON channels published by
// openarm01_robot_initializer_mujoco — engine-internal coupling, not part of
// the openarm01_gripper:v1 interface contract.
{
  peppy_schema: "node_v1",
  manifest: {
    name: "openarm01_gripper_mujoco",
    tag: "v1",
    depends_on: {
      nodes: [
        { name: "openarm01_robot_initializer_mujoco", tag: "v1", link_id: "sim" },
      ],
    },
  },
  interfaces: {
    conforms_to: [
      { name: "openarm01_gripper", tag: "v1" },
      // Always-on measured opening, mirroring the arm; consumers tell grippers
      // apart by gripper_id.
      { name: "openarm01_gripper_state_source", tag: "v1" },
    ],
  },
  execution: {
    language: "rust",
    container: {
      def_file: "apptainer.def",
    },
    parameters: {
      // The gripper_id at runtime (0 = left, 1 = right). Two instances are
      // expected; the bin's file-lock + gripper_id guard rejects collisions.
      gripper_id: "u8",
    },
  },
}
