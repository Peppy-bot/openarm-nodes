Bootstrap: docker
From: tuatini/peppy-rust-cargo-base

%files
    . /opt/openarm01_arm_test

%post
    export DEBIAN_FRONTEND=noninteractive

    cd /opt/openarm01_arm_test
    cargo build --release

    apt-get clean && rm -rf /var/lib/apt/lists/*

%runscript
    cd /opt/openarm01_arm_test
    exec ./target/release/openarm01_arm_test "$@"
