// This node represents a single arm in the openarm01 robot, the user will instanciate two different arm, each with a different `arm_id` input parameter.
// This is a root component node — openarm01_backbone depends on it, not the other way around.
// It is a "stupid" node that relays safe joint position commands from openarm01_backbone to either the real robot or the sims.
{
  peppy_schema: "node_v1",
  manifest: {
    name: "openarm01_arm",
    tag: "0.1.0",
    variants: [
      // The real thing
      {
        name: "default",
        source: {
          local: "./variants/default"
        }
      },
      // The isaac sim variant
      {
        name: "isaac",
        source: {
          local: "./variants/isaac"
        }
      },
      // The mujoco variant
      {
        name: "mujoco",
        source: {
          local: "./variants/mujoco"
        }
      },
    ]
  },
  // Non exhaustive list of interfaces
  interfaces: {
    actions: {
      exposes: [
        {
          name: "move_arm",
          goal_service: {
            request_message_format: {
              // The frequency in hertz at which the feedback is being sent
              feedback_frequency: "u32",
              // x, y, z
              desired_position: {
                $type: "array",
                $items: "f64",
                $length: 3
              },
              // quaternion x, y, z, w
              desired_orientation: {
                $type: "array",
                $items: "f64",
                $length: 4
              }
            },
            response_message_format: {
              accepted: "bool"
            }
          },
          // Streamed as the arm moves toward the goal
          feedback_topic: {
            qos_profile: "standard",
            message_format: {
              joint_positions: {
                $type: "array",
                $items: "f64"
              },
              current_ee_position: {
                $type: "array",
                $items: "f64",
                $length: 3
              },
              action_time: "f64"
            }
          },
          result_service: {
            response_message_format: {
              success: "bool",
              message: "string",
              final_joint_positions: {
                $type: "array",
                $items: "f64"
              },
              final_ee_position: {
                $type: "array",
                $items: "f64",
                $length: 3
              },
              action_time: "f64"
            }
          }
        },
        // Joint-space motion: backbone calls this after IK resolves joint angles.
        {
          name: "move_arm_joints",
          goal_service: {
            request_message_format: {
              feedback_frequency: "u32",
              joint_positions: {
                $type: "array",
                $items: "f64",
                $length: 7
              }
            },
            response_message_format: {
              accepted: "bool"
            }
          },
          feedback_topic: {
            qos_profile: "standard",
            message_format: {
              joint_positions: {
                $type: "array",
                $items: "f64",
                $length: 7
              },
              action_time: "f64"
            }
          },
          result_service: {
            response_message_format: {
              success: "bool",
              message: "string",
              final_joint_positions: {
                $type: "array",
                $items: "f64",
                $length: 7
              },
              action_time: "f64"
            }
          }
        }
      ]
    },
    services: {
      exposes: [
        {
          // Returns the runtime arm_id set in `execution.parameters` (allows `openarm01_backbone` to differentiate between the arms)
          name: "get_arm_id",
          response_message_format: {
            arm_id: "u8"
          }
        },
        {
          name: "get_joint_positions",
          response_message_format: {
            joint_positions: {
              $type: "array",
              $items: "f64",
              $length: 7
            }
          }
        }
      ]
    },
    topics: {
      emits: [
        // Joint state (whole-arm: 7 positions + 7 velocities, plus robot, step, stamp).
        // sim variants emit this on each physics step from MJCF/USD joint readings;
        // default (real) variant TODO once the CAN-bus driver is updated.
        {
          name: "joint_states",
          qos_profile: "sensor_data",
          message_format: {
            robot:      "string",
            step:       "u64",
            positions:  { $type: "array", $items: "f64" },
            velocities: { $type: "array", $items: "f64" },
            stamp:      "f64"
          }
        },
        // Per-side IMU. Body-mounted sensor reading on this arm.
        {
          name: "imu_left",
          qos_profile: "sensor_data",
          message_format: {
            robot:               "string",
            step:                "u64",
            orientation:         { $type: "array", $items: "f64", $length: 4 },
            angular_velocity:    { $type: "array", $items: "f64", $length: 3 },
            linear_acceleration: { $type: "array", $items: "f64", $length: 3 },
            stamp:               "f64"
          }
        },
        {
          name: "imu_right",
          qos_profile: "sensor_data",
          message_format: {
            robot:               "string",
            step:                "u64",
            orientation:         { $type: "array", $items: "f64", $length: 4 },
            angular_velocity:    { $type: "array", $items: "f64", $length: 3 },
            linear_acceleration: { $type: "array", $items: "f64", $length: 3 },
            stamp:               "f64"
          }
        },
        // TF tree (arm-link frames with parent + 6DoF pose).
        {
          name: "tf_tree",
          qos_profile: "sensor_data",
          message_format: {
            robot: "string",
            step:  "u64",
            frames: {
              $type: "array",
              $items: {
                $type:       "object",
                name:        "string",
                parent:      "string",
                position:    { $type: "array", $items: "f64", $length: 3 },
                orientation: { $type: "array", $items: "f64", $length: 4 }
              }
            },
            stamp: "f64"
          }
        }
      ]
    }
  }
}