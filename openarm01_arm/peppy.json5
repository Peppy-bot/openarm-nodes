// This node represents a single arm in the openarm01 robot, the user will instanciate two different arm, each with a different `arm_id` input parameter.
// This is a root component node — openarm01_backbone depends on it, not the other way around.
// It is a "stupid" node that relays safe joint position commands from openarm01_backbone to either the real robot or the sims.
{
  peppy_schema: "node_v1",
  manifest: {
    name: "openarm01_arm",
    tag: "v1",
    depends_on: {
      interfaces: [
        // Per-arm gravity + Coriolis compensation. Bound (in the launcher) to a
        // provider instance configured for this arm's side; conventionally the
        // srs_model node.
        { name: "gravity_coriolis_compensation", tag: "v1", link_id: "model" },
      ],
    },
  },
  execution: {
    language: "rust",
    container: {
      def_file: "apptainer.def"
    },
    parameters: {
      arm_id: "u8",
      can_interface: "string",
      // Hardware-loop rate (Hz).
      control_rate_hz: { $type: "u32", $default: 100 },
      // Per-cycle CAN read deadline (μs).
      recv_timeout_us: { $type: "u32", $default: 1000 },
      motion_timeout_s: { $type: "f64", $default: 30.0 },
      // Minimum trajectory duration (s). Actual duration = max(this, time implied by joint velocity limits).
      // Defaults to a deliberately slow 5 s for safe bring-up: the URDF velocity
      // limits are high, so without this floor a move would slam. Every move uses
      // this node-level floor — per-goal durations from the commander are not wired
      // yet (move_arm_joints carries no duration field). Lower it once trusted.
      min_motion_time_s: { $type: "f64", $default: 5.0 },
      // Per-joint peak velocity (rad/s) used to size the quintic trajectory
      // duration. Defaults are the OpenArm V1.0 URDF joint velocity limits.
      max_joint_velocity_rad_s_1: { $type: "f64", $default: 16.754666 },
      max_joint_velocity_rad_s_2: { $type: "f64", $default: 16.754666 },
      max_joint_velocity_rad_s_3: { $type: "f64", $default: 5.445426 },
      max_joint_velocity_rad_s_4: { $type: "f64", $default: 5.445426 },
      max_joint_velocity_rad_s_5: { $type: "f64", $default: 20.943946 },
      max_joint_velocity_rad_s_6: { $type: "f64", $default: 20.943946 },
      max_joint_velocity_rad_s_7: { $type: "f64", $default: 20.943946 },
      // MIT-control gains for trajectory mode, one per joint (1-indexed).
      // Match the openarm teleop config (Kp/Kd in config/leader.yaml).
      kp1: { $type: "f64", $default: 240.0 },
      kp2: { $type: "f64", $default: 240.0 },
      kp3: { $type: "f64", $default: 240.0 },
      kp4: { $type: "f64", $default: 240.0 },
      kp5: { $type: "f64", $default: 24.0 },
      kp6: { $type: "f64", $default: 31.0 },
      kp7: { $type: "f64", $default: 25.0 },
      kd1: { $type: "f64", $default: 3.0 },
      kd2: { $type: "f64", $default: 3.0 },
      kd3: { $type: "f64", $default: 3.0 },
      kd4: { $type: "f64", $default: 3.0 },
      kd5: { $type: "f64", $default: 0.2 },
      kd6: { $type: "f64", $default: 0.2 },
      kd7: { $type: "f64", $default: 0.2 },
      // Feedforward compensation scales. Each term is scaled independently so
      // bring-up can ramp them one at a time. Defaults are 0 (fail-safe): an arm
      // started without explicit scales applies no feedforward and is limp rather
      // than risking a wrong-signed torque. Once validated, set the openarm teleop
      // values: gravity_scale 1.0, coriolis_scale 0.1, friction_scale 0.3.
      gravity_scale: { $type: "f64", $default: 0.0 },
      coriolis_scale: { $type: "f64", $default: 0.0 },
      friction_scale: { $type: "f64", $default: 0.0 },
      // How long a streamed compensation sample stays usable before the model is
      // treated as down (float falls back to a PD position-hold; a trajectory
      // drops its model feedforward). ~5 cycles at 100 Hz.
      stale_timeout_ms: { $type: "u32", $default: 50 },
      // How often to print bring-up diagnostics (loop timing, poll latency,
      // compensation terms, tracking error). Lower it to watch a fast step more
      // closely; raise it to quiet the logs. Tunable at runtime (no rebuild).
      log_period_ms: { $type: "u32", $default: 1000 }
    }
  },
  interfaces: {
    conforms_to: [
      {
        name: "openarm01_arm",
        tag: "v1"
      },
      // Publishes measured joint state each control tick for the model node to
      // consume (it streams compensation back).
      {
        name: "joint_state",
        tag: "v1"
      }
    ],
    topics: {
      consumes: [
        // gravity + Coriolis feedforward, pushed by the model node each tick.
        { link_id: "model", name: "compensation" },
      ],
    },
  },
}
