// One arm of the openarm01 robot; instantiate twice, one per side, with a
// distinct `arm_id`. A root component node: openarm01_backbone depends on it.
// It owns the hardware control loop: gravity/Coriolis/friction feedforward
// (gravity and Coriolis from the in-process srs_model) for compliant float,
// quintic trajectory tracking for accepted move_arm / move_arm_joints goals,
// and ambient following of a streamed joint setpoint the rest of the time,
// bidirectional with the always-on `joint_states` stream. A move preempts the
// stream and the arm resumes following when it ends. The arm is a joint-space
// servo: task-space commanders solve IK upstream.
{
  peppy_schema: "node/v1",
  manifest: {
    name: "openarm01_arm",
    tag: "v1",
    depends_on: {
      interfaces: [
        // Streamed joint setpoints the arm follows between moves: optional and
        // wildcard (`from_any`), so the arm boots with no producer bound and
        // accepts any conforming one (teleop leader, planner, IK-solving
        // commander). Task-space intent stays upstream: the producer solves IK
        // and streams joints.
        {
          name: "openarm01_joint_command_source",
          tag: "v1",
          link_id: "commander",
          from_any: true
        },
      ],
    },
  },
  execution: {
    language: "rust",
    container: {
      def_file: "apptainer.def"
    },
    parameters: {
      arm_id: "u8",
      can_interface: "string",
      // URDF describing the robot (must include the world->base mount tree) and
      // the link where this arm's SRS chain starts. Used to build the rigid-body
      // model for the in-process gravity/Coriolis feedforward. The default is the
      // V1.0 description baked into this container (vendored from the repo-root
      // `description/`, since the build context is the node dir); override only to
      // point at a different description.
      urdf_path: { $type: "string", $default: "/opt/openarm01_arm/openarm_v10.urdf" },
      base_link: "string", // e.g. "openarm_left_link0"
      // Hardware-loop rate (Hz). Required: pick deliberately per deployment
      // (500 Hz matches the OpenArm reference) and confirm `overruns=0` at the
      // target rate during bring-up.
      control_rate_hz: "u32",
      // Per-cycle CAN read deadline (μs). Must fit the cycle budget (2 ms at 500 Hz).
      recv_timeout_us: { $type: "u32", $default: 1000 },
      // Per-joint peak velocity (rad/s) used to size the quintic trajectory
      // duration. Defaults are the OpenArm V1.0 URDF joint velocity limits.
      max_joint_velocity_rad_s_1: { $type: "f64", $default: 16.754666 },
      max_joint_velocity_rad_s_2: { $type: "f64", $default: 16.754666 },
      max_joint_velocity_rad_s_3: { $type: "f64", $default: 5.445426 },
      max_joint_velocity_rad_s_4: { $type: "f64", $default: 5.445426 },
      max_joint_velocity_rad_s_5: { $type: "f64", $default: 20.943946 },
      max_joint_velocity_rad_s_6: { $type: "f64", $default: 20.943946 },
      max_joint_velocity_rad_s_7: { $type: "f64", $default: 20.943946 },
      // End-effector linear-speed cap (m/s) for the Follow chase. The chase step
      // is scaled so the hand never translates faster than this, so a first
      // command or a producer hiccup far from the current pose eases over instead
      // of lunging. Bounds hand speed regardless of which joints move (a shoulder
      // sweep and a wrist twist that move the hand equally are capped equally); a
      // step that does not move the hand runs at the motor rate. Raise it for a
      // fast teleoperator; keep it gentle for bring-up.
      max_ee_velocity_m_s: { $type: "f64", $default: 0.25 },
      // MIT-control gains applied every control tick (startup, follow, and
      // moves), one per joint (1-indexed). Match the openarm teleop config
      // (Kp/Kd, identical in config/leader.yaml and follower.yaml).
      kp1: { $type: "f64", $default: 240.0 },
      kp2: { $type: "f64", $default: 240.0 },
      kp3: { $type: "f64", $default: 240.0 },
      kp4: { $type: "f64", $default: 240.0 },
      kp5: { $type: "f64", $default: 24.0 },
      kp6: { $type: "f64", $default: 31.0 },
      kp7: { $type: "f64", $default: 25.0 },
      kd1: { $type: "f64", $default: 3.0 },
      kd2: { $type: "f64", $default: 3.0 },
      kd3: { $type: "f64", $default: 3.0 },
      kd4: { $type: "f64", $default: 3.0 },
      kd5: { $type: "f64", $default: 0.2 },
      kd6: { $type: "f64", $default: 0.2 },
      kd7: { $type: "f64", $default: 0.2 },
      // Rate (Hz) of the always-on measured-state stream (`joint_states`).
      // Required: consumers' needs vary too much for a default to be meaningful.
      state_rate_hz: "u32",
      // How long (s) the arm keeps following a command stream after its last
      // message before releasing the lock and holding. The watchdog that stops
      // the arm when a producer dies, so it is a safety value with no universal
      // default: pick it per producer rate. Required.
      stream_timeout_s: "f64",
    }
  },
  interfaces: {
    conforms_to: [
      {
        name: "openarm01_arm",
        tag: "v1"
      },
      {
        name: "openarm01_joint_state_source",
        tag: "v1"
      },
      // Per-component readiness the real robot_initializer aggregates: ready once
      // motors are enabled and the control loop is serving.
      {
        name: "openarm01_hardware_ready",
        tag: "v1"
      }
    ],
    topics: {
      consumes: [
        {
          name: "joint_commands",
          link_id: "commander"
        }
      ],
    },
  },
}
