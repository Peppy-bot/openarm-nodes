# TODO: replace with tuatini/peppy-python-uv-base:latest once published
Bootstrap: docker
From: python:3.11-slim

%labels
    Name openarm01-backbone-mujoco
    Version 0.1.0

%environment
    export PYTHONPATH="/opt/peppy_python:/opt/mujoco_backbone/exts/mujoco.peppy.backbone:/opt/nodes_shared_code:/opt/mujoco_backbone/.peppy/libs/peppygen:$HOME/.peppy/libs/python:$PYTHONPATH"
    export PEPPY_BRIDGE_HEADLESS=${PEPPY_BRIDGE_HEADLESS:-0}
    export PEPPY_BRIDGE_NODE_NAME=sim
    export WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-wayland-0}
    export XDG_RUNTIME_DIR=${XDG_RUNTIME_DIR:-/run/user/$(id -u)}
    export PEPPY_ROBOT_ASSETS_DIR=${PEPPY_ROBOT_ASSETS_DIR:-/opt/robot_assets/openarm/mujoco}

# %setup runs on the HOST — copies pre-downloaded assets from the staging dir into the SIF.
# Run scripts/download_assets.sh before building to populate the staging dir.
%setup
    mkdir -p "${APPTAINER_ROOTFS}/opt/robot_assets/openarm/mujoco"
    if [ -d /tmp/.peppy_backbone_mujoco ] && [ -n "$(ls -A /tmp/.peppy_backbone_mujoco 2>/dev/null)" ]; then
        cp -r /tmp/.peppy_backbone_mujoco/. "${APPTAINER_ROOTFS}/opt/robot_assets/openarm/mujoco/"
        echo "INFO: Baked MuJoCo assets into SIF from /tmp/.peppy_backbone_mujoco"
    else
        echo "WARNING: /tmp/.peppy_backbone_mujoco not found or empty — run scripts/download_assets.sh first" >&2
    fi

%files

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive
    apt-get -o Acquire::Retries=5 -o Acquire::ForceIPv4=true update \
    && apt-get -o Acquire::Retries=5 -o Acquire::ForceIPv4=true install -y --no-install-recommends \
        libgl1 \
        libgl1-mesa-dri \
        libglib2.0-0 \
        libgomp1 \
        libosmesa6 \
        libwayland-client0 \
        libwayland-cursor0 \
        libwayland-egl1 \
        libxkbcommon0 \
        libegl1 \
        libegl-mesa0 \
        rclone \
        ca-certificates
    rm -rf /var/lib/apt/lists/*
    pip install --no-cache-dir \
        mujoco \
        numpy \
        pycapnp

%runscript
    cd /opt/mujoco_backbone
    _PRESET="${PEPPY_BRIDGE_PRESET:-mujoco_openarm}"
    _CONFIG="/opt/mujoco_backbone/config/presets/${_PRESET}.json5"
    if [ ! -f "${_CONFIG}" ]; then
        echo "ERROR: mujoco backbone preset not found: ${_CONFIG}" >&2
        echo "       Set PEPPY_BRIDGE_PRESET to a valid preset name." >&2
        exit 1
    fi
    export PEPPY_BRIDGE_CONFIG_PATH="${_CONFIG}"
    _LAUNCH=$(python3 -c "
import json, re, sys
cfg = json.loads(re.sub(r'//[^\n]*', '', open(sys.argv[1]).read()))
print(cfg['robot']['launch'])
" "${_CONFIG}" 2>/dev/null) || _LAUNCH="robots/openarm/openarm/launch.py"
    exec python3 /opt/mujoco_backbone/${_LAUNCH} "$@"
