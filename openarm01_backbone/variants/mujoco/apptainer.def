# TODO: replace with tuatini/peppy-python-uv-base:latest once published
Bootstrap: docker
From: python:3.11-slim

%labels
    Name openarm01-backbone-mujoco
    Version 0.1.0

%environment
    export PYTHONPATH="/opt/peppy_python:/opt/mujoco_backbone/exts/mujoco.peppy.backbone:/opt/nodes_shared_code:/opt/mujoco_backbone/.peppy/libs/peppygen:$HOME/.peppy/libs/python:$PYTHONPATH"
    export PEPPY_BRIDGE_HEADLESS=${PEPPY_BRIDGE_HEADLESS:-0}
    export PEPPY_BRIDGE_NODE_NAME=sim
    export WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-wayland-0}
    export XDG_RUNTIME_DIR=${XDG_RUNTIME_DIR:-/run/user/$(id -u)}
    export PEPPY_ROBOT_ASSETS_DIR=/opt/robot_assets/openarm/mujoco

# All assets (exts, robots, config, peppy.json5) are bind-mounted
# at runtime via mount_paths in peppy.json5 — nothing to copy at build time.
%files

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive
    apt-get -o Acquire::Retries=5 -o Acquire::ForceIPv4=true update \
    && apt-get -o Acquire::Retries=5 -o Acquire::ForceIPv4=true install -y --no-install-recommends \
        libgl1 \
        libgl1-mesa-dri \
        libglib2.0-0 \
        libgomp1 \
        libosmesa6 \
        libwayland-client0 \
        libwayland-cursor0 \
        libwayland-egl1 \
        libxkbcommon0 \
        libegl1 \
        libegl-mesa0 \
        rclone \
        ca-certificates
    rm -rf /var/lib/apt/lists/*
    pip install --no-cache-dir \
        mujoco \
        numpy \
        pycapnp
    mkdir -p /opt/robot_assets/openarm/mujoco
    if [ -n "${RCLONE_S3_ACCESS_KEY_ID:-}" ] && [ -n "${RCLONE_S3_SECRET_ACCESS_KEY:-}" ]; then
        RCLONE_CONFIG_R2_TYPE=s3 \
        RCLONE_CONFIG_R2_PROVIDER=Cloudflare \
        RCLONE_CONFIG_R2_ACCESS_KEY_ID="${RCLONE_S3_ACCESS_KEY_ID}" \
        RCLONE_CONFIG_R2_SECRET_ACCESS_KEY="${RCLONE_S3_SECRET_ACCESS_KEY}" \
        RCLONE_CONFIG_R2_ENDPOINT="https://b9abcee11c090aef5279f874ff078826.r2.cloudflarestorage.com" \
        rclone copy r2:peppy-data01/openarm01/mujoco/assets/ /opt/robot_assets/openarm/mujoco/ --progress
    else
        echo "WARNING: R2 credentials not set — assets not baked into SIF; set PEPPY_ROBOT_ASSETS_DIR at runtime" >&2
    fi

%runscript
    cd /opt/mujoco_backbone
    _PRESET="${PEPPY_BRIDGE_PRESET:-mujoco_openarm}"
    _CONFIG="/opt/mujoco_backbone/config/presets/${_PRESET}.json5"
    if [ ! -f "${_CONFIG}" ]; then
        echo "ERROR: mujoco backbone preset not found: ${_CONFIG}" >&2
        echo "       Set PEPPY_BRIDGE_PRESET to a valid preset name." >&2
        exit 1
    fi
    export PEPPY_BRIDGE_CONFIG_PATH="${_CONFIG}"
    _LAUNCH=$(python3 -c "
import json, re, sys
cfg = json.loads(re.sub(r'//[^\n]*', '', open(sys.argv[1]).read()))
print(cfg['robot']['launch'])
" "${_CONFIG}" 2>/dev/null) || _LAUNCH="robots/openarm/openarm/launch.py"
    exec python3 /opt/mujoco_backbone/${_LAUNCH} "$@"
