# TODO: replace with a custom pre-built image once published (avoids 15 GB OCI fetch)
Bootstrap: docker
From: nvcr.io/nvidia/isaac-sim:5.1.0

%labels
    Name openarm01-backbone-isaac
    Version 0.1.0

%environment
    export PYTHONPATH="/opt/peppy_python:/opt/isaac_backbone/exts/omni.peppy.backbone:/opt/nodes_shared_code:/opt/isaac_backbone/.peppy/libs:$HOME/.peppy/libs/python:$PYTHONPATH"
    export PEPPY_BRIDGE_HEADLESS=${PEPPY_BRIDGE_HEADLESS:-0}
    export PEPPY_BRIDGE_NODE_NAME=sim
    export DISPLAY=${DISPLAY:-:1}
    export PEPPY_ROBOT_ASSETS_DIR=/opt/robot_assets/openarm/isaac

%files

%post
    set -eux
    apt-get -o Acquire::Retries=5 -o Acquire::ForceIPv4=true update \
    && apt-get -o Acquire::Retries=5 -o Acquire::ForceIPv4=true install -y --no-install-recommends \
        rclone \
    && rm -rf /var/lib/apt/lists/*
    mkdir -p /opt/robot_assets/openarm/isaac
    if [ -n "${RCLONE_S3_ACCESS_KEY_ID:-}" ] && [ -n "${RCLONE_S3_SECRET_ACCESS_KEY:-}" ]; then
        RCLONE_CONFIG_R2_TYPE=s3 \
        RCLONE_CONFIG_R2_PROVIDER=Cloudflare \
        RCLONE_CONFIG_R2_ACCESS_KEY_ID="${RCLONE_S3_ACCESS_KEY_ID}" \
        RCLONE_CONFIG_R2_SECRET_ACCESS_KEY="${RCLONE_S3_SECRET_ACCESS_KEY}" \
        RCLONE_CONFIG_R2_ENDPOINT="https://b9abcee11c090aef5279f874ff078826.r2.cloudflarestorage.com" \
        rclone copy r2:peppy-data01/openarm01/isaac/assets/ /opt/robot_assets/openarm/isaac/ --progress
    else
        echo "WARNING: R2 credentials not set — assets not baked into SIF; set PEPPY_ROBOT_ASSETS_DIR at runtime" >&2
    fi

%runscript
    cd /isaac-sim
    _PRESET="${PEPPY_BRIDGE_PRESET:-isaac_openarm}"
    _CONFIG="/opt/isaac_backbone/config/presets/${_PRESET}.json5"
    if [ ! -f "${_CONFIG}" ]; then
        echo "ERROR: isaac backbone preset not found: ${_CONFIG}" >&2
        echo "       Set PEPPY_BRIDGE_PRESET to a valid preset name." >&2
        exit 1
    fi
    export PEPPY_BRIDGE_CONFIG_PATH="${_CONFIG}"
    exec ./python.sh /opt/isaac_backbone/robots/openarm/openarm/launch.py "$@"
