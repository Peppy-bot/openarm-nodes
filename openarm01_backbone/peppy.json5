// openarm01_backbone — orchestrator. Receives motion commands from openarm01_joint_commander,
// routes each to the correct openarm01_arm / openarm01_gripper instance (left/right), and relays
// feedback + result upward. Sim/real agnostic — it never touches a sim or hardware API; the
// component nodes own that abstraction. No variants.
{
  peppy_schema: "node_v1",
  manifest: {
    name: "openarm01_backbone",
    tag: "0.1.0",
    depends_on: {
      // Startup ordering only. Backbone polls is_ready, then discovers arm/gripper instances.
      nodes: [
        {
          name: "openarm01_robot_initializer",
          tag: "0.1.0",
          local_id: "robot_init"
        },
        {
          name: "openarm01_arm",
          tag: "0.1.0",
          local_id: "arm"
        },
        {
          name: "openarm01_gripper",
          tag: "0.1.0",
          local_id: "gripper"
        }
      ]
    }
  },
  interfaces: {
    actions: {
      exposes: [
        {
          // Joint-space arm motion. arm_id selects the target arm instance (0 = left, 1 = right).
          // Backbone resolves arm_id to a running instance and forwards to arm's move_arm_joints.
          name: "move_arm_joints",
          goal_service: {
            request_message_format: {
              arm_id: "u8",
              // Feedback rate (Hz) the caller wants while the arm moves.
              feedback_frequency: "u32",
              joint_positions: {
                $type: "array",
                $items: "f64",
                $length: 7
              }
            },
            response_message_format: {
              accepted: "bool"
            }
          },
          feedback_topic: {
            qos_profile: "standard",
            message_format: {
              joint_positions: {
                $type: "array",
                $items: "f64",
                $length: 7
              },
              action_time: "f64"
            }
          },
          result_service: {
            response_message_format: {
              success: "bool",
              message: "string",
              final_joint_positions: {
                $type: "array",
                $items: "f64",
                $length: 7
              },
              action_time: "f64"
            }
          }
        },
        {
          // Gripper motion. gripper_id selects the target gripper instance (0 = left, 1 = right).
          name: "move_gripper",
          goal_service: {
            request_message_format: {
              gripper_id: "u8",
              feedback_frequency: "u32",
              // Target gripper opening in meters (0.0 = closed, 0.044 = fully open on V10).
              position: "f64"
            },
            response_message_format: {
              accepted: "bool"
            }
          },
          feedback_topic: {
            qos_profile: "standard",
            message_format: {
              joint_positions: {
                $type: "array",
                $items: "f64"
              },
              action_time: "f64"
            }
          },
          result_service: {
            response_message_format: {
              success: "bool",
              message: "string",
              final_joint_positions: {
                $type: "array",
                $items: "f64"
              },
              action_time: "f64"
            }
          }
        }
      ],
      // Downstream actions backbone fires after selecting the target instance.
      consumes: [
        {
          local_node_id: "arm",
          name: "move_arm_joints"
        },
        {
          local_node_id: "gripper",
          name: "move_gripper"
        }
      ]
    },
    services: {
      // is_ready gates startup; get_arm_id/get_gripper_id map each running instance to its side.
      consumes: [
        {
          local_node_id: "robot_init",
          name: "is_ready"
        },
        {
          local_node_id: "arm",
          name: "get_arm_id"
        },
        {
          local_node_id: "gripper",
          name: "get_gripper_id"
        }
      ]
    }
  },
  execution: {
    language: "rust",
    container: {
      def_file: "apptainer.def"
    }
  }
}
