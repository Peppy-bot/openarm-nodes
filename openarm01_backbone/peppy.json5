// openarm01_backbone: the bimanual coordination hub node. Consumes the operator
// arm_joint_commands stream and both arms' arm_states; exposes the joint /
// Cartesian / gripper move actions; conforms to arm_governed_setpoints (the
// per-arm stream the arms follow) and collision_status; and relays move_gripper
// to the per-side grippers. See src/main.rs for the architecture.
{
  peppy_schema: "node/v1",
  manifest: {
    name: "openarm01_backbone",
    tag: "v1",
    depends_on: {
      interfaces: [
        {
          name: "openarm01_robot_initializer",
          tag: "v1",
          link_id: "robot_init"
        },
        // Operator joint setpoint stream, `from_any`: the hub binds to whatever
        // commander is running and tells sides apart by arm_id.
        {
          name: "openarm01_arm_joint_commands",
          tag: "v1",
          link_id: "commander",
          from_any: true
        },
        // Measured joint state of both arms, the governor's d_now and the
        // trajectory anchor. Wildcard: both arm/sim instances publish it, told
        // apart by arm_id.
        {
          name: "openarm01_arm_states",
          tag: "v1",
          link_id: "arm_states",
          from_any: true
        },
        // Runtime on/off for the governor. Wildcard + optional: the hub holds its
        // launch-time default until the first message.
        {
          name: "openarm01_governor_control",
          tag: "v1",
          link_id: "collision_ctrl",
          from_any: true
        },
        // Per-side gripper move targets (relay unchanged).
        {
          name: "openarm01_gripper_actions",
          tag: "v1",
          link_id: "left_gripper"
        },
        {
          name: "openarm01_gripper_actions",
          tag: "v1",
          link_id: "right_gripper"
        }
      ]
    }
  },
  interfaces: {
    conforms_to: [
      // The governed per-arm setpoint stream (positions + velocity feedforward).
      {
        name: "openarm01_arm_governed_setpoints",
        tag: "v1"
      },
      {
        // Live nearest-pair distance + links, for the operator readout.
        name: "openarm01_collision_status",
        tag: "v1"
      },
      // The joint / Cartesian arm move actions (move_arm_joints, move_arm),
      // addressed by arm_id. The hub runs each move itself (trajectory + governor
      // + governed stream); progress is observed on arm_states.
      {
        name: "openarm01_arm_actions",
        tag: "v1"
      }
    ],
    actions: {
      exposes: [
        {
          // Gripper motion. gripper_id selects the target gripper (0 = left,
          // 1 = right).
          name: "move_gripper",
          goal_service: {
            request_message_format: {
              gripper_id: "u8",
              position: "f64"
            },
            response_message_format: {
              accepted: "bool"
            }
          },
          result_service: {
            response_message_format: {
              success: "bool",
              message: "string",
              final_joint_positions: {
                $type: "array",
                $items: "f64"
              },
              action_time: "f64"
            }
          }
        }
      ],
      // Downstream gripper move actions the hub relays to, per side.
      consumes: [
        {
          link_id: "left_gripper",
          name: "move_gripper"
        },
        {
          link_id: "right_gripper",
          name: "move_gripper"
        }
      ]
    },
    topics: {
      consumes: [
        {
          name: "arm_joint_commands",
          link_id: "commander"
        },
        {
          name: "arm_states",
          link_id: "arm_states"
        },
        {
          name: "governor_control",
          link_id: "collision_ctrl"
        }
      ]
    },
    services: {
      consumes: [
        {
          link_id: "robot_init",
          name: "is_ready"
        }
      ]
    }
  },
  execution: {
    language: "rust",
    container: {
      def_file: "apptainer.def"
    },
    parameters: {
      // Per-side base links selecting the two SRS chains in the embedded OpenArm
      // description (openarm_description), used for both srs_model arms and the
      // bimanual collision model. The description is a fixed OpenArm v10: the
      // governor's torso proxy is hand-fitted to its mesh (see the openarm_v10
      // module), and the collision model's build() aborts without the expected torso.
      left_base: { $type: "string", $default: "openarm_left_link0" },
      right_base: { $type: "string", $default: "openarm_right_link0" },
      // Coordination loop rate (Hz): the rate governed setpoints are streamed at.
      control_rate_hz: "u32",
      // Self-collision governor band (m), signed surface distance between the two
      // arms. At/under d_stop motion toward contact is fully stopped; at/over
      // d_safe it is unthrottled; between, it ramps linearly. Separating motion
      // is never throttled (recovery from a tangle is always allowed). Require
      // 0 < d_stop < d_safe. The collision model was validated against
      // d_stop=0.005, d_safe=0.02: the rest-pose clearance (~24 mm of the nearest
      // checked pair) sits just above d_safe, so the home pose is unthrottled and
      // an approach throttles within ~2 cm.
      d_stop: "f64",
      d_safe: "f64",
      // Governor state at launch, before the first governor_control message.
      collision_governor_enabled: "bool",
      // Per-joint peak velocity (rad/s) sizing the quintic trajectories and the
      // stream chase. OpenArm V1.0 URDF joint velocity limits; the hub is the sole
      // owner of motion sizing.
      max_joint_velocity_rad_s_1: { $type: "f64", $default: 16.754666 },
      max_joint_velocity_rad_s_2: { $type: "f64", $default: 16.754666 },
      max_joint_velocity_rad_s_3: { $type: "f64", $default: 5.445426 },
      max_joint_velocity_rad_s_4: { $type: "f64", $default: 5.445426 },
      max_joint_velocity_rad_s_5: { $type: "f64", $default: 20.943946 },
      max_joint_velocity_rad_s_6: { $type: "f64", $default: 20.943946 },
      max_joint_velocity_rad_s_7: { $type: "f64", $default: 20.943946 },
      // End-effector linear-speed cap (m/s) for the stream chase, used only until
      // the first governor_control message; after that the operator's streamed cap
      // (openarm01_joint_commander) governs. Require > 0. The sim launchers set a
      // permissive value; the real arm a conservative one.
      max_ee_velocity_m_s: "f64",
      // How long (s) the hub keeps following an operator stream after its last
      // message before releasing the lock and holding.
      stream_timeout_s: "f64",
    }
  }
}
