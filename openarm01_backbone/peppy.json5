// openarm01_backbone — orchestrator. Receives motion commands from
// openarm01_joint_commander, routes each to the correct openarm01_arm /
// openarm01_gripper instance (left/right), and relays feedback + result upward.
// Sim/real agnostic — component nodes own that abstraction.
{
  peppy_schema: "node_v1",
  manifest: {
    name: "openarm01_backbone",
    tag: "v1",
    depends_on: {
      // Per-side link_ids make left/right dispatch a compile-time choice — no
      // runtime get_arm_id/get_gripper_id discovery, no stack_list scan. The
      // launcher picks the concrete impl per slot (real / mujoco / isaac).
      interfaces: [
        {
          name: "openarm01_robot_initializer",
          tag: "v1",
          link_id: "robot_init"
        },
        {
          name: "openarm01_arm",
          tag: "v1",
          link_id: "left_arm"
        },
        {
          name: "openarm01_arm",
          tag: "v1",
          link_id: "right_arm"
        },
        {
          name: "openarm01_gripper",
          tag: "v1",
          link_id: "left_gripper"
        },
        {
          name: "openarm01_gripper",
          tag: "v1",
          link_id: "right_gripper"
        }
      ]
    }
  },
  interfaces: {
    actions: {
      exposes: [
        {
          // Joint-space arm motion. arm_id selects the target arm instance (0 = left, 1 = right).
          // Backbone resolves arm_id to a running instance and forwards to arm's move_arm_joints.
          name: "move_arm_joints",
          goal_service: {
            request_message_format: {
              arm_id: "u8",
              // Feedback rate (Hz) the caller wants while the arm moves.
              feedback_frequency: "u32",
              joint_positions: {
                $type: "array",
                $items: "f64",
                $length: 7
              }
            },
            response_message_format: {
              accepted: "bool"
            }
          },
          feedback_topic: {
            qos_profile: "standard",
            message_format: {
              joint_positions: {
                $type: "array",
                $items: "f64",
                $length: 7
              },
              action_time: "f64"
            }
          },
          result_service: {
            response_message_format: {
              success: "bool",
              message: "string",
              final_joint_positions: {
                $type: "array",
                $items: "f64",
                $length: 7
              },
              action_time: "f64"
            }
          }
        },
        {
          // Gripper motion. gripper_id selects the target gripper instance (0 = left, 1 = right).
          name: "move_gripper",
          goal_service: {
            request_message_format: {
              gripper_id: "u8",
              feedback_frequency: "u32",
              // Target gripper opening in meters (0.0 = closed, 0.044 = fully open on V10).
              position: "f64"
            },
            response_message_format: {
              accepted: "bool"
            }
          },
          feedback_topic: {
            qos_profile: "standard",
            message_format: {
              joint_positions: {
                $type: "array",
                $items: "f64"
              },
              action_time: "f64"
            }
          },
          result_service: {
            response_message_format: {
              success: "bool",
              message: "string",
              final_joint_positions: {
                $type: "array",
                $items: "f64"
              },
              action_time: "f64"
            }
          }
        }
      ],
      // Downstream actions backbone fires. Per-side link_ids: dispatch on goal.arm_id /
      // goal.gripper_id selects the consumed module at compile time.
      consumes: [
        {
          link_id: "left_arm",
          name: "move_arm_joints"
        },
        {
          link_id: "right_arm",
          name: "move_arm_joints"
        },
        {
          link_id: "left_gripper",
          name: "move_gripper"
        },
        {
          link_id: "right_gripper",
          name: "move_gripper"
        }
      ]
    },
    services: {
      // is_ready gates startup. get_arm_id / get_gripper_id are gone — left/right identity
      // is launcher-pinned via the link_ids above, so there is no runtime discovery to do.
      consumes: [
        {
          link_id: "robot_init",
          name: "is_ready"
        }
      ]
    }
  },
  execution: {
    language: "rust",
    container: {
      def_file: "apptainer.def"
    }
  }
}
