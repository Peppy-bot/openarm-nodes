// This node represents a single gripper in the openarm robot, the user will instanciate two different gripper, each with a different `gripper_id` input parameter.
// This is a root component node; openarm_backbone depends on it, not the other way around.
// It is a "stupid" node that relays gripper commands from openarm_backbone to either the real robot or the sims.
{
  peppy_schema: "node/v1",
  manifest: {
    name: "openarm_gripper",
    tag: "v1",
    implements: [
      // Per-component readiness for the real robot_initializer.
      { name: "openarm_hardware_ready", tag: "v1", link_id: "ready" },
    ],
    depends_on: {
      pairings: [
        // The exclusive control conversation with ONE backbone instance:
        // streamed opening setpoints in, measured aperture back, both scoped
        // to the pair (no gripper_id demux). Optional: the gripper boots
        // unpaired (moves still work via backbone goals) and is paired at
        // the backbone's start.
        { name: "gripper_link", tag: "v1", role: "follower", link_id: "backbone", optional: true },
      ],
    },
  },
  interfaces: {
    topics: {
      emits: [
        // The `backbone` pairing slot: the topic this role emits.
        { link_id: "backbone", name: "gripper_states" },
      ],
      consumes: [
        // The counterpart role's topic on the same slot.
        { link_id: "backbone", name: "gripper_setpoints" },
      ],
    },
    services: {
      exposes: [
        { link_id: "ready", name: "is_ready" },
      ],
    },
  },
  execution: {
    language: "rust",
    container: {
      def_file: "apptainer.def"
    },
    parameters: {
      gripper_id: "u8",
      can_interface: "string",
      // Hardware-loop rate (Hz). Pick deliberately per deployment; the stack
      // currently unifies on 100 Hz across arms and grippers.
      control_rate_hz: "u32",
      // Per-cycle CAN read deadline (μs). Must fit the cycle budget (10 ms at 100 Hz).
      recv_timeout_us: { $type: "u32", $default: 1000 },
      // Rate (Hz) of the always-on measured-opening stream (`gripper_states`);
      // consumers' needs vary too much for a default to be meaningful.
      state_rate_hz: "u32"
    }
  },
}
