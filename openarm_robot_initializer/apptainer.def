Bootstrap: docker
From: tuatini/peppy-rust-cargo-base:latest

%labels
    Name openarm_robot_initializer
    Version v1

%files
    . /opt/openarm_robot_initializer

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive

    cd /opt/openarm_robot_initializer
    cargo build --release

%runscript
    cd /opt/openarm_robot_initializer
    exec ./target/release/openarm_robot_initializer
