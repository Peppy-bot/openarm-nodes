// Real-hardware robot_initializer: aggregates the per-component
// openarm_hardware_ready signals from both arms and grippers and exposes the
// robot-level is_ready backbone gates on. Returns ready:true only once every
// bound component has enabled its motors and started serving. Implements
// openarm_robot_initializer:v1 alongside the _mujoco / _isaac siblings, which
// gate on scene load instead.
{
  peppy_schema: "node/v1",
  manifest: {
    name: "openarm_robot_initializer",
    tag: "v1",
    implements: [
      { name: "openarm_robot_initializer", tag: "v1", link_id: "robot_ready" },
    ],
    depends_on: {
      // Per-side link_ids mirror backbone: the launcher pins each to the concrete
      // arm/gripper instance whose readiness this node aggregates.
      contracts: [
        { name: "openarm_hardware_ready", tag: "v1", link_id: "left_arm" },
        { name: "openarm_hardware_ready", tag: "v1", link_id: "right_arm" },
        { name: "openarm_hardware_ready", tag: "v1", link_id: "left_gripper" },
        { name: "openarm_hardware_ready", tag: "v1", link_id: "right_gripper" }
      ]
    }
  },
  interfaces: {
    services: {
      exposes: [
        { link_id: "robot_ready", name: "is_ready" },
      ],
      consumes: [
        { link_id: "left_arm", name: "is_ready" },
        { link_id: "right_arm", name: "is_ready" },
        { link_id: "left_gripper", name: "is_ready" },
        { link_id: "right_gripper", name: "is_ready" }
      ]
    }
  },
  execution: {
    language: "rust",
    container: {
      def_file: "apptainer.def",
    },
  },
}
